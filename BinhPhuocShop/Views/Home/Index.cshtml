@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = "Trang chủ";
    var hexashop = "/hexashop";
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? new List<dynamic>();
    var featured = ViewBag.FeaturedProducts as IEnumerable<dynamic> ?? new List<dynamic>();
    var bestSelling = ViewBag.BestSellingProducts as IEnumerable<dynamic> ?? new List<dynamic>();
    var latest = ViewBag.LatestProducts as IEnumerable<dynamic> ?? new List<dynamic>();
    var homeBlocks = ViewBag.HomeCategoryBlocks as IEnumerable<BinhPhuocShop.Models.HomeCategoryBlockViewModel> ?? new List<BinhPhuocShop.Models.HomeCategoryBlockViewModel>();
    var siteName = ViewBag.SiteName ?? "Bình Phước Shop";
    var siteDesc = ViewBag.SiteDescription ?? "Thương hiệu chuyên kinh doanh, phân phối giày da nam. Chất lượng cao, nhiều bộ sưu tập độc đáo.";
}

<!-- ***** Main Banner Area Start ***** -->
<div class="main-banner" id="top">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-6">
                <div class="left-content">
                    <div class="thumb">
                        <div class="inner-content">
                            <h4>Chào mừng đến @siteName</h4>
                            <span>@siteDesc</span>
                            <div class="main-border-button">
                                <a asp-controller="Products" asp-action="Index">Mua sắm ngay!</a>
                            </div>
                        </div>
                            <img src="@(ViewBag.HeroBackground ?? hexashop + "/assets/images/left-banner-image.jpg")" alt="@siteName" style="width: 100%; height: auto; object-fit: cover;">
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="right-content">
                    <div class="row">
                        @{
                            var mainCategories = categories.Take(4).ToList();
                            var bannerImages = new[] { 
                                ViewBag.BannerGiayNam ?? hexashop + "/assets/images/baner-right-image-01.jpg",
                                ViewBag.BannerGiayNu ?? hexashop + "/assets/images/baner-right-image-02.jpg",
                                ViewBag.BannerDepNam ?? hexashop + "/assets/images/baner-right-image-03.jpg",
                                hexashop + "/assets/images/baner-right-image-04.jpg"
                            };
                            var bannerTitles = new[] { "Giày Nam", "Giày Nữ", "Dép Nam", "Phụ Kiện" };
                            var bannerDescs = new[] { "Sản phẩm Giày Nam", "Sản phẩm Giày Nữ", "Sản phẩm Dép Nam", "Sản phẩm Phụ Kiện" };
                        }
                        @for (int i = 0; i < 4; i++)
                        {
                            var cat = i < mainCategories.Count ? mainCategories[i] : null;
                            <div class="col-lg-6">
                                <div class="right-first-image">
                                    <div class="thumb">
                                        <div class="inner-content">
                                            <h4>@(cat?.Name ?? bannerTitles[i])</h4>
                                            <span>@(cat != null ? $"Sản phẩm {cat.Name}" : bannerDescs[i])</span>
                                        </div>
                                        <div class="hover-content">
                                            <div class="inner">
                                                <h4>@(cat?.Name ?? bannerTitles[i])</h4>
                                                <p>Khám phá bộ sưu tập @(cat?.Name ?? bannerTitles[i]) mới nhất</p>
                                                <div class="main-border-button">
                                                    @if (cat != null)
                                                    {
                                                        <a asp-controller="Collections" asp-action="Index" asp-route-slug="@(cat.Slug ?? "")">Xem thêm</a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-controller="Products" asp-action="Index">Xem thêm</a>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <img src="@bannerImages[i]" alt="@(cat?.Name ?? bannerTitles[i])" style="width: 100%; height: auto; object-fit: cover;">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ***** Main Banner Area End ***** -->

@{
    var categorySections = new List<dynamic>();
    var homeBlocksList = homeBlocks as IEnumerable<dynamic> ?? new List<dynamic>();
    var categoriesList = categories as IEnumerable<dynamic> ?? new List<dynamic>();
    var featuredList = featured as IEnumerable<dynamic> ?? new List<dynamic>();
    var latestList = latest as IEnumerable<dynamic> ?? new List<dynamic>();
    
    if (homeBlocksList != null && homeBlocksList.Count() > 0)
    {
        foreach (var block in homeBlocksList)
        {
            categorySections.Add(new { Category = block.Category, Products = block.Products });
        }
    }
    else if (categoriesList != null && categoriesList.Count() > 0)
    {
        foreach (var cat in categoriesList.Take(3))
        {
            var catId = cat.Id;
            var catProducts = featuredList.Where(p => p.CategoryId.HasValue && p.CategoryId.Value == catId).Take(4).ToList();
            if (catProducts == null || catProducts.Count == 0) 
            {
                catProducts = latestList.Where(p => p.CategoryId.HasValue && p.CategoryId.Value == catId).Take(4).ToList();
            }
            categorySections.Add(new { Category = cat, Products = catProducts });
        }
    }
}

@foreach (var section in categorySections)
{
    var sectionId = section.Category.Slug?.Replace("-", "") ?? "section" + section.Category.Id;
    <!-- ***** @(section.Category.Name) Area Starts ***** -->
    <section class="section product-section fade-in-section" id="@sectionId">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="section-heading text-center">
                        <h2 class="section-title">@(section.Category.Name) Mới Nhất</h2>
                        <span class="section-subtitle">Khám phá bộ sưu tập @(section.Category.Name) đa dạng và chất lượng cao</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="men-item-carousel">
                        <div class="owl-men-item owl-carousel">
                            @{
                                var productsList = section.Products as IEnumerable<dynamic> ?? new List<dynamic>();
                                var hasProducts = productsList != null && productsList.Count() > 0;
                            }
                            @if (hasProducts)
                            {
                                @foreach (var product in productsList)
                                {
                                    var price = product.SalePrice ?? product.Price;
                                    var hasSalePrice = product.SalePrice != null && product.SalePrice != product.Price;
                                    var oldPrice = hasSalePrice ? product.Price : (decimal?)null;
                                    <div class="item product-item">
                                        <div class="thumb">
                                            <div class="hover-content">
                                                <ul>
                                                    <li><a asp-controller="Products" asp-action="Detail" asp-route-id="@product.Id"><i class="fa fa-eye"></i></a></li>
                                                    <li><a href="#" onclick="addToCart(@product.Id); return false;"><i class="fa fa-shopping-cart"></i></a></li>
                                                </ul>
                                            </div>
                                            <img src="@(product.ImageUrl ?? hexashop + "/assets/images/men-01.jpg")" alt="@product.Name" style="width: 100%; height: auto;">
                                        </div>
                                        <div class="down-content">
                                            <h4>@product.Name</h4>
                                            <div class="price-wrapper">
                                                <span class="current-price">@price.ToString("N0")₫</span>
                                                @if (hasSalePrice && oldPrice != null)
                                                {
                                                    <span class="old-price">@((decimal)oldPrice).ToString("N0")₫</span>
                                                }
                                            </div>
                                            <ul class="stars">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    <li><i class="fa fa-star"></i></li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="col-12 text-center p-5">
                                    <p>Chưa có sản phẩm nào trong danh mục này.</p>
                                    <a asp-controller="Products" asp-action="Index" class="btn btn-dark mt-3">Xem tất cả sản phẩm</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- ***** @(section.Category.Name) Area Ends ***** -->
}

<!-- ***** Explore Area Starts ***** -->
<section class="section fade-in-section" id="explore">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="left-content">
                    <h2>Khám Phá Sản Phẩm Của Chúng Tôi</h2>
                    <span>@siteDesc</span>
                    <div class="quote">
                        <i class="fa fa-quote-left"></i><p>Chúng tôi cam kết mang đến những sản phẩm chất lượng cao với giá cả hợp lý nhất.</p>
                    </div>
                    <p>Với nhiều năm kinh nghiệm trong ngành giày dép, chúng tôi tự hào là địa chỉ tin cậy cho mọi khách hàng.</p>
                    <p>Hãy đến với chúng tôi để trải nghiệm dịch vụ tốt nhất và sản phẩm chất lượng cao.</p>
                    <div class="main-border-button">
                        <a asp-controller="Products" asp-action="Index">Khám phá thêm</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="right-content">
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="leather">
                                <h4>Giày Da</h4>
                                <span>Bộ sưu tập mới nhất</span>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="first-image">
                                <img src="@(hexashop)/assets/images/explore-image-01.jpg" alt="Giày da" style="width: 100%; height: auto; object-fit: cover;">
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="second-image">
                                <img src="@(hexashop)/assets/images/explore-image-02.jpg" alt="Dép" style="width: 100%; height: auto; object-fit: cover;">
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="types">
                                <h4>Nhiều Loại</h4>
                                <span>Hơn @(ViewBag.ProductCountAll ?? 0) Sản phẩm</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Explore Area Ends ***** -->

<!-- Flower/Snowfall Effect Container -->
<div id="flower-container"></div>

@section Scripts {
    <script src="@(hexashop)/assets/js/home-effects.js"></script>
    <script>
        $(document).ready(function() {
            // Khởi tạo carousel cho các section sản phẩm với smooth transitions
            if ($('.owl-men-item').length > 0) {
                $('.owl-men-item').each(function() {
                    $(this).owlCarousel({
                        items: 4,
                        loop: true,
                        margin: 30,
                        nav: true,
                        dots: false,
                        autoplay: true,
                        autoplayTimeout: 4000,
                        autoplayHoverPause: true,
                        smartSpeed: 800,
                        animateOut: 'fadeOut',
                        animateIn: 'fadeIn',
                        responsive: {
                            0: { items: 1 },
                            480: { items: 2 },
                            768: { items: 3 },
                            992: { items: 4 }
                        }
                    });
                });
            }

            // Initialize fade-in animations
            initFadeInAnimations();
        });

        function addToCart(productId) {
            $.ajax({
                url: '@Url.Action("Add", "Cart")',
                method: 'POST',
                data: {
                    productId: productId,
                    quantity: 1,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.ok) {
                        alert(response.msg || 'Đã thêm vào giỏ hàng');
                        location.reload();
                    } else {
                        alert(response.msg || 'Có lỗi xảy ra');
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra khi thêm vào giỏ hàng');
                }
            });
        }

        function initFadeInAnimations() {
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver(function(entries) {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('fade-in-visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.fade-in-section').forEach(section => {
                observer.observe(section);
            });
        }
    </script>
}
