@model BinhPhuocShop.Models.ContactMessage
@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = "Liên hệ";
    var hexashop = "/hexashop";
}

<!-- ***** Contact Area Starts ***** -->
<section class="section" id="contact">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="contact-form">
                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        <h4 class="mb-4 fw-bold">Gửi tin nhắn cho chúng tôi</h4>
                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success">
                                <i class="fa fa-check-circle me-2"></i>@TempData["Success"]
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Họ và tên *</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập họ và tên của bạn" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Số điện thoại *</label>
                            <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" required />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email *</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Nhập địa chỉ email" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Nội dung tin nhắn *</label>
                            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Nhập nội dung tin nhắn của bạn" required></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-dark w-100">
                            <i class="fa fa-paper-plane me-2"></i>Gửi liên hệ
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="contact-info">
                    <h4 class="mb-4 fw-bold">Thông tin liên hệ</h4>
                    <div class="mb-4">
                        <h6 class="mb-2"><i class="fa fa-map-marker me-2" style="color: #667eea;"></i>Địa chỉ</h6>
                        <p class="ms-4">@(ViewBag.SiteAddress ?? ViewBag.Address ?? "123 Đường ABC, Quận XYZ, TP. Hồ Chí Minh")</p>
                    </div>
                    <div class="mb-4">
                        <h6 class="mb-2"><i class="fa fa-phone me-2" style="color: #667eea;"></i>Điện thoại</h6>
                        <p class="ms-4"><a href="tel:@(ViewBag.SitePhone ?? ViewBag.Phone ?? "0984843218")" style="color: #667eea; text-decoration: none;">@(ViewBag.SitePhone ?? ViewBag.Phone ?? "0984843218")</a></p>
                    </div>
                    <div class="mb-4">
                        <h6 class="mb-2"><i class="fa fa-envelope me-2" style="color: #667eea;"></i>Email</h6>
                        <p class="ms-4"><a href="mailto:@(ViewBag.SiteEmail ?? ViewBag.Email ?? "contact@binhphuocshop.vn")" style="color: #667eea; text-decoration: none;">@(ViewBag.SiteEmail ?? ViewBag.Email ?? "contact@binhphuocshop.vn")</a></p>
                    </div>
                    <div class="mb-4">
                        <h6 class="mb-2"><i class="fa fa-clock-o me-2" style="color: #667eea;"></i>Giờ làm việc</h6>
                        <p class="ms-4">8:00 AM - 10:00 PM Hàng ngày</p>
                    </div>
                </div>
                <div class="mt-4">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3724.5400238871257!2d105.84948329999999!3d21.011067699999998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab94acc75ef5%3A0x90571614e5e0c1b2!2sMULGATI!5e0!3m2!1svi!2s!4v1670226856071" width="100%" height="300" style="border:0; border-radius: 8px;" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Contact Area Ends ***** -->
