@{
    var hexashop = "/hexashop";
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? new List<dynamic>();
    var cartCount = ViewBag.CartCount ?? 0;
    var userName = ViewBag.UserName as string;
    var siteName = ViewBag.SiteName ?? "Bình Phước Shop";
    var sitePhone = ViewBag.SitePhone ?? "0984843218";
    var siteEmail = ViewBag.SiteEmail ?? "contact@binhphuocshop.vn";
    var siteAddress = ViewBag.SiteAddress ?? "123 Đường ABC, Quận XYZ, TP. Hồ Chí Minh";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="@(ViewBag.SiteDescription ?? "Thương hiệu chuyên kinh doanh, phân phối giày da nam. Chất lượng cao, nhiều bộ sưu tập độc đáo.")">
    <title>@ViewData["Title"] - @siteName</title>
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700,800,900&display=swap" rel="stylesheet">
    
    <!-- Font Awesome CDN - Đảm bảo icons hiển thị đầy đủ -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" integrity="sha512-SfTiTlX6kk+qitfevl/7LibUOeJWlt9rbyDn92a1DqWOw9vWG2MFoays0sgObmWazO5BQPmZnn7f6CvK8+5Y9Q==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <!-- Additional CSS Files -->
    <link rel="stylesheet" type="text/css" href="@(hexashop)/assets/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="@(hexashop)/assets/css/font-awesome.css">
    <link rel="stylesheet" href="@(hexashop)/assets/css/templatemo-hexashop.css">
    <link rel="stylesheet" href="@(hexashop)/assets/css/owl-carousel.css">
    <link rel="stylesheet" href="@(hexashop)/assets/css/lightbox.css">
    <link rel="stylesheet" href="@(hexashop)/assets/css/custom.css">
</head>
<body>
    <!-- ***** Preloader Start ***** -->
    <div id="preloader">
        <div class="jumper">
            <div></div>
            <div></div>
            <div></div>
        </div>
    </div>  
    <!-- ***** Preloader End ***** -->
    
    <!-- Thông báo chung cho toàn bộ trang -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="margin: 0; border-radius: 0; position: fixed; top: 0; left: 0; right: 0; z-index: 9999; padding: 15px 20px;">
            <i class="fa fa-check-circle"></i> <strong>Thành công!</strong> @TempData["Success"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 24px; cursor: pointer;">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <script>
            setTimeout(function() {
                $('.alert-success').fadeOut('slow');
            }, 5000);
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="margin: 0; border-radius: 0; position: fixed; top: 0; left: 0; right: 0; z-index: 9999; padding: 15px 20px;">
            <i class="fa fa-exclamation-circle"></i> <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; font-size: 24px; cursor: pointer;">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <script>
            setTimeout(function() {
                $('.alert-danger').fadeOut('slow');
            }, 7000);
        </script>
    }
    
    <!-- ***** Header Area Start ***** -->
    <header class="header-area header-sticky">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <nav class="main-nav">
                        <!-- ***** Logo Start ***** -->
                        <a asp-controller="Home" asp-action="Index" class="logo" style="display: flex; align-items: center; text-decoration: none; font-family: 'Poppins', sans-serif;">
                            <span style="font-size: 26px; font-weight: 700; color: #2a2a2a; letter-spacing: 0.5px;">BìnhPhướcShop</span>
                        </a>
                        <!-- ***** Logo End ***** -->
                        <!-- ***** Menu Start ***** -->
                        <ul class="nav">
                            <li class="scroll-to-section">
                                <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">Trang chủ</a>
                            </li>
                            <li class="scroll-to-section">
                                <a asp-controller="Pages" asp-action="GioiThieu" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pages" && ViewContext.RouteData.Values["action"]?.ToString() == "GioiThieu" ? "active" : "")">Giới thiệu</a>
                            </li>
                            <li class="submenu">
                                <a href="javascript:;">Sản Phẩm</a>
                                <ul>
                                    @{
                                        var productCategorySlugs = new[] { "giay-nam", "giay-nu", "dep-nam", "dep-nu", "phu-kien" };
                                        var productCategories = new List<dynamic>();
                                        foreach (var cat in categories)
                                        {
                                            var slug = cat.Slug?.ToString() ?? "";
                                            if (productCategorySlugs.Any(s => string.Equals(s, slug, StringComparison.OrdinalIgnoreCase)))
                                            {
                                                productCategories.Add(cat);
                                            }
                                        }
                                        productCategories = productCategories.OrderBy(c => {
                                            var slug = c.Slug?.ToString() ?? "";
                                            var index = Array.FindIndex(productCategorySlugs, s => string.Equals(s, slug, StringComparison.OrdinalIgnoreCase));
                                            return index >= 0 ? index : 999;
                                        }).ToList();
                                        
                                        // Fallback nếu không có categories trong DB
                                        if (productCategories.Count == 0)
                                        {
                                            productCategories = new List<dynamic> {
                                                new { Name = "Giày nam", Slug = "giay-nam" },
                                                new { Name = "Giày nữ", Slug = "giay-nu" },
                                                new { Name = "Dép nam", Slug = "dep-nam" },
                                                new { Name = "Dép nữ", Slug = "dep-nu" },
                                                new { Name = "Phụ Kiện", Slug = "phu-kien" }
                                            };
                                        }
                                    }
                                    @foreach (var cat in productCategories)
                                    {
                                        <li><a asp-controller="Collections" asp-action="Index" asp-route-slug="@(cat.Slug?.ToString() ?? "")">@cat.Name</a></li>
                                    }
                                </ul>
                            </li>
                            <li class="scroll-to-section">
                                <a asp-controller="Blog" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")">Blog</a>
                            </li>
                            <li class="scroll-to-section">
                                <a asp-controller="Contact" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")">Liên hệ</a>
                            </li>
                            <li class="scroll-to-section">
                                <a asp-controller="Cart" asp-action="Index">
                                    <i class="fa fa-shopping-cart"></i> Giỏ hàng <span class="badge badge-light">@cartCount</span>
                                </a>
                            </li>
                            <li class="submenu">
                                <a href="javascript:;">Tài khoản</a>
                                <ul>
                                    @if (!string.IsNullOrEmpty(userName))
                                    {
                                        <li><a asp-controller="Account" asp-action="Profile">Thông tin cá nhân</a></li>
                                        <li>
                                            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" style="background:none;border:none;color:inherit;cursor:pointer;width:100%;text-align:left;padding:5px 15px;">Đăng xuất</button>
                                            </form>
                                        </li>
                                    }
                                    else
                                    {
                                        <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                                        <li><a asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                                    }
                                </ul>
                            </li>
                        </ul>        
                        <a class='menu-trigger'>
                            <span>Menu</span>
                        </a>
                        <!-- ***** Menu End ***** -->
                    </nav>
                </div>
            </div>
        </div>
    </header>
    <!-- ***** Header Area End ***** -->

    @RenderBody()

    <!-- ***** Subscribe Area Starts ***** -->
    <div class="subscribe">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <div class="section-heading">
                        <h2>Đăng ký nhận bản tin để nhận ưu đãi 30%</h2>
                        <span>Nhận thông tin về sản phẩm mới và các chương trình khuyến mãi đặc biệt.</span>
                    </div>
                    <form id="subscribe" action="" method="get">
                        <div class="row">
                          <div class="col-lg-5">
                            <fieldset>
                              <input name="name" type="text" id="name" placeholder="Tên của bạn" required="">
                            </fieldset>
                          </div>
                          <div class="col-lg-5">
                            <fieldset>
                              <input name="email" type="email" id="email" placeholder="Email của bạn" required="">
                            </fieldset>
                          </div>
                          <div class="col-lg-2">
                            <fieldset>
                              <button type="submit" id="form-submit" class="main-dark-button"><i class="fa fa-paper-plane"></i></button>
                            </fieldset>
                          </div>
                        </div>
                    </form>
                </div>
                <div class="col-lg-4">
                    <div class="row">
                        <div class="col-6">
                            <ul>
                                <li>Địa chỉ:<br><span>@siteAddress</span></li>
                                <li>Điện thoại:<br><span>@sitePhone</span></li>
                                <li>Email:<br><span>@siteEmail</span></li>
                            </ul>
                        </div>
                        <div class="col-6">
                            <ul>
                                <li>Giờ làm việc:<br><span>8:00 AM - 10:00 PM Hàng ngày</span></li>
                                <li>Mạng xã hội:<br><span><a href="#">Facebook</a>, <a href="#">Instagram</a>, <a href="#">Zalo</a></span></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- ***** Subscribe Area Ends ***** -->
    
    <!-- ***** Footer Start ***** -->
    <footer class="fade-in-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6">
                    <div class="first-item">
                        <div class="logo">
                            <h3 style="color: #fff; font-weight: 700; margin: 0;">@siteName</h3>
                        </div>
                        <ul>
                            <li><a href="#"><i class="fa fa-map-marker"></i> @siteAddress</a></li>
                            <li><a href="mailto:@siteEmail"><i class="fa fa-envelope"></i> @siteEmail</a></li>
                            <li><a href="tel:@sitePhone"><i class="fa fa-phone"></i> @sitePhone</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4>Mua sắm &amp; Danh mục</h4>
                    <ul>
                        @foreach (var cat in categories.Take(5))
                        {
                            <li><a asp-controller="Collections" asp-action="Index" asp-route-slug="@(cat.Slug ?? "")">@cat.Name</a></li>
                        }
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4>Liên kết hữu ích</h4>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a asp-controller="Pages" asp-action="GioiThieu">Giới thiệu</a></li>
                        <li><a asp-controller="Blog" asp-action="Index">Blog</a></li>
                        <li><a asp-controller="Contact" asp-action="Index">Liên hệ</a></li>
                        <li><a asp-controller="Products" asp-action="Index">Sản phẩm</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4>Trợ giúp &amp; Thông tin</h4>
                    <ul>
                        <li><a asp-controller="Pages" asp-action="HuongDanMuaHang">Hướng dẫn mua hàng</a></li>
                        <li><a asp-controller="Pages" asp-action="ChinhSachVanChuyen">Vận chuyển</a></li>
                        <li><a asp-controller="Pages" asp-action="ChinhSachDoiHang">Đổi trả hàng</a></li>
                        <li><a asp-controller="Pages" asp-action="ChinhSachBaoHanh">Bảo hành</a></li>
                        <li><a asp-controller="Pages" asp-action="ChinhSachQuyenRiengTu">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-12">
                    <div class="under-footer">
                        <p>Copyright © @DateTime.Now.Year @siteName. Tất cả quyền được bảo lưu.</p>
                        <ul>
                            <li><a href="#" title="Facebook"><i class="fa fa-facebook"></i></a></li>
                            <li><a href="#" title="Twitter"><i class="fa fa-twitter"></i></a></li>
                            <li><a href="#" title="LinkedIn"><i class="fa fa-linkedin"></i></a></li>
                            <li><a href="#" title="Instagram"><i class="fa fa-instagram"></i></a></li>
                            <li><a href="#" title="Zalo"><i class="fa fa-comments"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    

    <!-- jQuery -->
    <script src="@(hexashop)/assets/js/jquery-2.1.0.min.js"></script>

    <!-- Bootstrap -->
    <script src="@(hexashop)/assets/js/popper.js"></script>
    <script src="@(hexashop)/assets/js/bootstrap.min.js"></script>

    <!-- Plugins -->
    <script src="@(hexashop)/assets/js/owl-carousel.js"></script>
    <script src="@(hexashop)/assets/js/accordions.js"></script>
    <script src="@(hexashop)/assets/js/datepicker.js"></script>
    <script src="@(hexashop)/assets/js/scrollreveal.min.js"></script>
    <script src="@(hexashop)/assets/js/waypoints.min.js"></script>
    <script src="@(hexashop)/assets/js/jquery.counterup.min.js"></script>
    <script src="@(hexashop)/assets/js/imgfix.min.js"></script> 
    <script src="@(hexashop)/assets/js/slick.js"></script> 
    <script src="@(hexashop)/assets/js/lightbox.js"></script> 
    <script src="@(hexashop)/assets/js/isotope.js"></script> 
    
    <!-- Global Init -->
    <script src="@(hexashop)/assets/js/custom.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
