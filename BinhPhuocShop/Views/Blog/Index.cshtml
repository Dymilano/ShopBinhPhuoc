@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = ViewData["Title"] ?? "Blog";
    var hexashop = "/hexashop";
}

<div class="container py-5">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8 mb-4 mb-lg-0">
            <!-- Page Title -->
            <div class="mb-4">
                <h1 class="h2 fw-bold mb-2" style="color: #2a2a2a; font-size: 32px;">@(ViewData["Title"])</h1>
                <p class="text-muted mb-0">Khám phá những bài viết mới nhất về giày dép và phong cách</p>
            </div>

            <!-- Category Filter -->
            @if (ViewBag.BlogCategories != null)
            {
                <div class="mb-4 pb-3 border-bottom">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var (slug, name) in (IEnumerable<(string, string)>)ViewBag.BlogCategories)
                        {
                            var isActive = (ViewBag.Category as string) == slug;
                            <a asp-action="Index" asp-route-category="@(string.IsNullOrEmpty(slug) ? null : slug)" 
                               class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-secondary")" 
                               style="border-radius: 20px; padding: 6px 16px; font-size: 14px; transition: all 0.3s ease;">
                                @name
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Blog Posts -->
            @if (ViewBag.Posts != null && ((IEnumerable<dynamic>)ViewBag.Posts).Any())
            {
                <div class="blog-posts-list">
                    @foreach (var post in (IEnumerable<dynamic>)ViewBag.Posts)
                    {
                        var postDate = (DateTime)(post.PublishedAt ?? post.CreatedAt);
                        var postId = (int)post.Id;
                        var postTitle = post.Title as string ?? "";
                        var postSummary = post.Summary as string ?? "";
                        var postImageUrl = post.ImageUrl as string ?? hexashop + "/assets/images/men-01.jpg";
                        var blogCategory = post.BlogCategory as string ?? "";

                        <article class="blog-post-card mb-4">
                            <div class="row g-0">
                                <div class="col-md-4">
                                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@postId" class="blog-post-image">
                                        <img src="@postImageUrl" alt="@postTitle" class="img-fluid w-100 h-100" style="object-fit: cover; border-radius: 8px 0 0 8px; min-height: 200px;">
                                    </a>
                                </div>
                                <div class="col-md-8">
                                    <div class="blog-post-content p-3 p-md-4">
                                        @if (!string.IsNullOrEmpty(blogCategory))
                                        {
                                            <span class="badge bg-primary mb-2" style="font-size: 11px; font-weight: 500; padding: 4px 10px;">
                                                @blogCategory
                                            </span>
                                        }
                                        <h3 class="h5 mb-2">
                                            <a asp-controller="Blog" asp-action="Detail" asp-route-id="@postId" 
                                               class="text-dark text-decoration-none fw-semibold" 
                                               style="line-height: 1.4; display: block; transition: color 0.3s ease;">
                                                @postTitle
                                            </a>
                                        </h3>
                                        @if (!string.IsNullOrEmpty(postSummary))
                                        {
                                            <p class="text-muted mb-3" style="font-size: 14px; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                                @postSummary
                                            </p>
                                        }
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="blog-post-meta text-muted" style="font-size: 13px;">
                                                <i class="fa fa-calendar me-1"></i>
                                                <span>@postDate.ToString("dd/MM/yyyy")</span>
                                            </div>
                                            <a asp-controller="Blog" asp-action="Detail" asp-route-id="@postId" 
                                               class="btn btn-sm btn-outline-primary" 
                                               style="border-radius: 20px; padding: 4px 16px; font-size: 13px;">
                                                Đọc thêm <i class="fa fa-arrow-right ms-1"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Blog pagination" class="mt-5">
                        <ul class="pagination justify-content-center">
                            @if ((int)ViewBag.Page > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-page="@((int)ViewBag.Page - 1)" asp-route-category="@ViewBag.Category">
                                        <i class="fa fa-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            @for (var i = 1; i <= (int)ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-category="@ViewBag.Category">@i</a>
                                </li>
                            }
                            @if ((int)ViewBag.Page < (int)ViewBag.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-page="@((int)ViewBag.Page + 1)" asp-route-category="@ViewBag.Category">
                                        <i class="fa fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fa fa-newspaper-o" style="font-size: 64px; color: #ddd; margin-bottom: 20px;"></i>
                    <p class="text-muted mb-0">Chưa có bài viết nào.</p>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <aside class="blog-sidebar">
                <!-- Latest Posts -->
                <div class="sidebar-widget mb-4">
                    <h4 class="widget-title mb-3">
                        <i class="fa fa-newspaper-o me-2"></i>
                        Bài viết mới nhất
                    </h4>
                    <ul class="list-unstyled mb-0">
                        @if (ViewBag.Posts != null && ((IEnumerable<dynamic>)ViewBag.Posts).Any())
                        {
                            @foreach (var p in ((IEnumerable<dynamic>)ViewBag.Posts).Take(5))
                            {
                                var pDate = (DateTime)(p.PublishedAt ?? p.CreatedAt);
                                var pId = (int)p.Id;
                                var pTitle = p.Title as string ?? "";
                                <li class="sidebar-post-item mb-3 pb-3 border-bottom">
                                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@pId" 
                                       class="d-block text-decoration-none mb-1 fw-semibold" 
                                       style="color: #2a2a2a; font-size: 14px; line-height: 1.5; transition: color 0.3s ease;">
                                        @pTitle
                                    </a>
                                    <span class="text-muted" style="font-size: 12px;">
                                        <i class="fa fa-calendar me-1"></i>@pDate.ToString("dd/MM/yyyy")
                                    </span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="text-muted" style="font-size: 14px;">Chưa có bài viết.</li>
                        }
                    </ul>
                </div>

                <!-- Categories -->
                <div class="sidebar-widget">
                    <h4 class="widget-title mb-3">
                        <i class="fa fa-folder me-2"></i>
                        Danh mục
                    </h4>
                    <ul class="list-unstyled mb-0">
                        @if (ViewBag.BlogCategories != null)
                        {
                            @foreach (var (slug, name) in (IEnumerable<(string, string)>)ViewBag.BlogCategories)
                            {
                                var isActive = (ViewBag.Category as string) == slug;
                                <li class="mb-2">
                                    <a asp-action="Index" asp-route-category="@(string.IsNullOrEmpty(slug) ? null : slug)" 
                                       class="text-decoration-none d-flex align-items-center justify-content-between"
                                       style="color: @(isActive ? "#667eea" : "#666"); font-size: 14px; padding: 8px 0; transition: color 0.3s ease;">
                                        <span>@name</span>
                                        @if (isActive)
                                        {
                                            <i class="fa fa-check text-primary"></i>
                                        }
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </aside>
        </div>
    </div>
</div>

<style>
    .blog-post-card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .blog-post-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
        transform: translateY(-2px);
    }

    .blog-post-image {
        display: block;
        overflow: hidden;
        height: 100%;
    }

    .blog-post-image img {
        transition: transform 0.3s ease;
    }

    .blog-post-card:hover .blog-post-image img {
        transform: scale(1.05);
    }

    .blog-post-content h3 a:hover {
        color: #667eea !important;
    }

    .sidebar-widget {
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .widget-title {
        font-size: 18px;
        font-weight: 600;
        color: #2a2a2a;
        padding-bottom: 12px;
        border-bottom: 2px solid #f0f0f0;
    }

    .sidebar-post-item a:hover {
        color: #667eea !important;
    }

    .pagination .page-link {
        color: #667eea;
        border-color: #e0e0e0;
        padding: 8px 16px;
    }

    .pagination .page-item.active .page-link {
        background-color: #667eea;
        border-color: #667eea;
    }

    .pagination .page-link:hover {
        background-color: #f8f9fa;
        color: #667eea;
    }

    @@media (max-width: 768px) {
        .blog-post-card .row > div {
            border-radius: 8px !important;
        }
        
        .blog-post-image img {
            border-radius: 8px 8px 0 0 !important;
        }
    }
</style>
