@{
    Layout = "_StoreLayout";
    ViewData["Title"] = ViewData["Title"] ?? "Bài viết";
    var store = "/store";
}
<!-- Title page (CozaStore) -->
<section class="bg-img1 txt-center p-lr-15 p-tb-92" style="background-image: url('@(store)/images/bg-02.jpg'); background-color: #f5f5f5;">
    <h2 class="ltext-105 cl0 txt-center">@(ViewData["Title"])</h2>
</section>

<!-- Content page -->
<section class="bg0 p-t-62 p-b-60">
    <div class="container">
        <div class="row">
            <div class="col-md-8 col-lg-9 p-b-80">
                <div class="p-r-45 p-r-0-lg">
                    @if (ViewBag.BlogCategories != null)
                    {
                        <div class="flex-w flex-sb-m p-b-30">
                            @foreach (var (slug, name) in (IEnumerable<(string, string)>)ViewBag.BlogCategories)
                            {
                                <a asp-action="Index" asp-route-category="@(string.IsNullOrEmpty(slug) ? null : slug)" class="stext-106 cl6 hov1 bor3 trans-04 m-r-32 m-tb-5 @(ViewBag.Category as string == slug ? "how-active1" : "")">@name</a>
                            }
                        </div>
                    }
                    @if (ViewBag.Posts != null && ((IEnumerable<dynamic>)ViewBag.Posts).Any())
                    {
                        @foreach (var post in (IEnumerable<dynamic>)ViewBag.Posts)
                        {
                            var postDate = (DateTime)(post.PublishedAt ?? post.CreatedAt);
                            <div class="p-b-63">
                                <a asp-controller="Blog" asp-action="Detail" asp-route-id="@post.Id" class="hov-img0 how-pos5-parent">
                                    <img src="@(post.ImageUrl ?? store + "/images/product-01.jpg")" alt="@post.Title">
                                    <div class="flex-col-c-m size-123 bg9 how-pos5">
                                        <span class="ltext-107 cl2 txt-center">@postDate.Day</span>
                                        <span class="stext-109 cl3 txt-center">Tháng @postDate.Month @postDate.Year</span>
                                    </div>
                                </a>
                                <div class="p-t-32">
                                    <h4 class="p-b-15">
                                        <a asp-controller="Blog" asp-action="Detail" asp-route-id="@post.Id" class="ltext-108 cl2 hov-cl1 trans-04">@post.Title</a>
                                    </h4>
                                    @if (!string.IsNullOrEmpty(post.Summary as string))
                                    {
                                        <p class="stext-117 cl6">@post.Summary</p>
                                    }
                                    <div class="flex-w flex-sb-m p-t-18">
                                        <span class="stext-111 cl2">@postDate.ToString("dd/MM/yyyy")</span>
                                        <a asp-controller="Blog" asp-action="Detail" asp-route-id="@post.Id" class="stext-101 cl2 hov-cl1 trans-04 m-tb-10">
                                            Xem thêm <i class="fa fa-long-arrow-right m-l-9"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                        {
                            <div class="flex-l-m flex-w w-full p-t-45">
                                <ul class="flex-w flex-c-m">
                                    @for (var i = 1; i <= (int)ViewBag.TotalPages; i++)
                                    {
                                        <li class="p-b-10">
                                            <a asp-action="Index" asp-route-page="@i" asp-route-category="@ViewBag.Category" class="flex-c-m stext-101 cl2 size-107 bg2 bor1 hov-btn1 p-lr-15 trans-04 m-r-2 @(i == (int)ViewBag.Page ? "bg3" : "")">@i</a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="stext-117 cl6 text-center p-t-60">Chưa có bài viết nào.</p>
                    }
                </div>
            </div>
            <!-- Sidebar -->
            <div class="col-md-4 col-lg-3">
                <div class="p-l-20 p-l-0-lg">
                    <h4 class="mtext-112 cl2 p-b-33 stext-113">Bài viết mới nhất</h4>
                    <ul>
                        @if (ViewBag.Posts != null && ((IEnumerable<dynamic>)ViewBag.Posts).Any())
                        {
                            @foreach (var p in ((IEnumerable<dynamic>)ViewBag.Posts).Take(5))
                            {
                                <li class="flex-w flex-sb-m p-b-20">
                                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@p.Id" class="stext-107 cl7 hov-cl1 trans-04 w-full">@p.Title</a>
                                    <span class="stext-108 cl6">@(((DateTime)(p.PublishedAt ?? p.CreatedAt)).ToString("dd/MM/yyyy"))</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="stext-107 cl6">Chưa có bài viết.</li>
                        }
                    </ul>
                    <h4 class="mtext-112 cl2 p-b-33 stext-113 p-t-40">Danh mục bài viết</h4>
                    <ul>
                        @if (ViewBag.BlogCategories != null)
                        {
                            @foreach (var (slug, name) in (IEnumerable<(string, string)>)ViewBag.BlogCategories)
                            {
                                <li class="p-b-10"><a asp-action="Index" asp-route-category="@(string.IsNullOrEmpty(slug) ? null : slug)" class="stext-107 cl7 hov-cl1 trans-04">@name</a></li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
