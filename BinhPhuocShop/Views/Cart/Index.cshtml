@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = "Giỏ hàng";
    var hexashop = "/hexashop";
    var items = ViewBag.CartItems as IEnumerable<BinhPhuocShop.Models.CartItem> ?? new List<BinhPhuocShop.Models.CartItem>();
    var total = (decimal)(ViewBag.CartTotal ?? 0);
}

@Html.AntiForgeryToken()

@if (items.Any())
{
    <section class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mb-4 mb-lg-0">
                    <div class="card">
                        <div class="card-header">
                            <h4 class="mb-0"><i class="fa fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h4>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Sản phẩm</th>
                                            <th style="width: 15%;">Giá</th>
                                            <th style="width: 20%;">Số lượng</th>
                                            <th style="width: 15%;">Thành tiền</th>
                                            <th style="width: 10%;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in items)
                                        {
                                            <tr data-product-id="@item.ProductId" data-size="@(item.Size ?? "")">
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <img src="@(item.ImageUrl ?? hexashop + "/assets/images/men-01.jpg")" alt="@item.ProductName" style="width: 80px; height: 80px; object-fit: cover; margin-right: 15px; border-radius: 5px;">
                                                        <div>
                                                            <a asp-controller="Products" asp-action="Detail" asp-route-id="@item.ProductId" class="fw-bold" style="color: #2a2a2a; text-decoration: none;">@item.ProductName</a>
                                                            @if (!string.IsNullOrEmpty(item.Size))
                                                            {
                                                                <p class="text-muted mb-0" style="font-size: 14px;">Size: @item.Size</p>
                                                            }
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="cart-price fw-semibold">@item.Price.ToString("N0")₫</td>
                                                <td>
                                                    <div class="quantity buttons_added">
                                                        <input type="button" value="-" class="minus qty-minus" data-product-id="@item.ProductId" data-size="@(item.Size ?? "")">
                                                        <input type="number" step="1" min="1" max="99" name="quantity" class="input-text qty text cart-qty-input" value="@item.Quantity" size="4" readonly>
                                                        <input type="button" value="+" class="plus qty-plus" data-product-id="@item.ProductId" data-size="@(item.Size ?? "")">
                                                    </div>
                                                </td>
                                                <td class="cart-amount fw-bold" style="color: #667eea;">@item.Amount.ToString("N0")₫</td>
                                                <td>
                                                    <button type="button" class="btn btn-danger btn-sm cart-remove-btn" data-product-id="@item.ProductId" data-size="@(item.Size ?? "")" title="Xóa">
                                                        <i class="fa fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer">
                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark">
                                <i class="fa fa-arrow-left me-2"></i>Tiếp tục mua sắm
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="cart-summary">
                        <h4 class="mb-4"><i class="fa fa-calculator me-2"></i>Tổng giỏ hàng</h4>
                        <div class="total-row">
                            <span>Tổng cộng:</span>
                            <strong id="cart-total-value" style="color: #667eea; font-size: 1.5rem;">@total.ToString("N0")₫</strong>
                        </div>
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-dark w-100 mt-4">
                            <i class="fa fa-credit-card me-2"></i>Thanh toán
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
else
{
    <section class="section">
        <div class="container">
            <div class="text-center p-5">
                <i class="fa fa-shopping-cart" style="font-size: 64px; color: #ccc; margin-bottom: 20px;"></i>
                <h3>Giỏ hàng của bạn đang trống</h3>
                <p class="text-muted mb-4">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-dark">Xem sản phẩm</a>
            </div>
        </div>
    </section>
}

@section Scripts {
    <script src="@(hexashop)/assets/js/quantity.js"></script>
    <script>
    (function() {
      var csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
      function getToken() {
        if (csrf) return csrf;
        var m = document.cookie.match(/__RequestVerificationToken=([^;]+)/);
        return m ? m[1] : '';
      }
      function updateQty(productId, size, quantity) {
        var fd = new FormData();
        fd.append('productId', productId);
        fd.append('size', size);
        fd.append('quantity', quantity);
        fd.append('__RequestVerificationToken', getToken());
        fetch('@Url.Action("Update", "Cart")', { method: 'POST', body: fd })
          .then(r => r.json()).then(function(data) {
            if (data.ok) {
              var row = document.querySelector('tr[data-product-id="' + productId + '"][data-size="' + size + '"]');
              if (row && data.count === 0) location.reload();
              else if (row) {
                var amt = row.querySelector('.cart-amount');
                var priceEl = row.querySelector('.cart-price');
                if (amt && priceEl) {
                  var price = parseFloat(priceEl.textContent.replace(/[^\d]/g, ''));
                  amt.textContent = (price * quantity).toLocaleString('vi-VN') + '₫';
                }
                var totalEl = document.getElementById('cart-total-value');
                if (totalEl) totalEl.textContent = (data.total || 0).toLocaleString('vi-VN') + '₫';
              }
            }
          });
      }
      function removeItem(productId, size) {
        var fd = new FormData();
        fd.append('productId', productId);
        fd.append('size', size);
        fd.append('__RequestVerificationToken', getToken());
        fetch('@Url.Action("Remove", "Cart")', { method: 'POST', body: fd })
          .then(r => r.json()).then(function(data) {
            if (data.ok) {
              var row = document.querySelector('tr[data-product-id="' + productId + '"][data-size="' + size + '"]');
              if (row) row.remove();
              var totalEl = document.getElementById('cart-total-value');
              if (totalEl) totalEl.textContent = (data.total || 0).toLocaleString('vi-VN') + '₫';
              if (data.count === 0) location.reload();
            }
          });
      }
      document.querySelectorAll('.qty-minus').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var productId = this.dataset.productId, size = this.dataset.size || '';
          var input = this.parentElement.querySelector('.cart-qty-input');
          if (!input) return;
          var q = Math.max(1, parseInt(input.value, 10) - 1);
          input.value = q;
          updateQty(productId, size, q);
        });
      });
      document.querySelectorAll('.qty-plus').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var productId = this.dataset.productId, size = this.dataset.size || '';
          var input = this.parentElement.querySelector('.cart-qty-input');
          if (!input) return;
          var q = Math.min(99, parseInt(input.value, 10) + 1);
          input.value = q;
          updateQty(productId, size, q);
        });
      });
      document.querySelectorAll('.cart-remove-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (confirm('Xóa sản phẩm này khỏi giỏ hàng?'))
            removeItem(this.dataset.productId, this.dataset.size || '');
        });
      });
    })();
    </script>
}
