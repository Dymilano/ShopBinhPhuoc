@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = "Thanh toán";
    var hexashop = "/hexashop";
    var items = ViewBag.CartItems as IEnumerable<BinhPhuocShop.Models.CartItem> ?? new List<BinhPhuocShop.Models.CartItem>();
    var total = (decimal)(ViewBag.CartTotal ?? 0);
    var error = ViewBag.Error as string;
    var customerName = ViewBag.CustomerName as string ?? "";
    var customerEmail = ViewBag.CustomerEmail as string ?? "";
    var customerPhone = ViewBag.CustomerPhone as string ?? "";
    var customerAddress = ViewBag.CustomerAddress as string ?? "";
}

<!-- Page Title -->
<div class="container mt-4 mb-4">
    <div class="row">
        <div class="col-lg-12">
            <h2 class="fw-bold" style="color: #2a2a2a; font-size: 2rem;">Thanh toán</h2>
        </div>
    </div>
</div>

<section class="section">
    <div class="container">
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        <form asp-controller="Checkout" asp-action="Index" method="post">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-lg-8">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h4>Thông tin giao hàng</h4>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Họ và tên *</label>
                                <input type="text" name="customerName" class="form-control" value="@customerName" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số điện thoại *</label>
                                <input type="tel" name="phone" class="form-control" value="@customerPhone" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" value="@customerEmail" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Địa chỉ giao hàng *</label>
                                <textarea name="address" class="form-control" rows="3" required>@customerAddress</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ghi chú</label>
                                <textarea name="note" class="form-control" rows="2" placeholder="Ghi chú về đơn hàng..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h4>Đơn hàng của bạn</h4>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-3">
                                @foreach (var item in items)
                                {
                                    <li class="d-flex justify-content-between mb-2">
                                        <span>@item.ProductName @(string.IsNullOrEmpty(item.Size) ? "" : "- Size " + item.Size) x @item.Quantity</span>
                                        <span>@item.Amount.ToString("N0")₫</span>
                                    </li>
                                }
                            </ul>
                            <hr>
                            <div class="d-flex justify-content-between mb-3">
                                <strong>Tổng cộng:</strong>
                                <strong>@total.ToString("N0")₫</strong>
                            </div>
                            <button type="submit" class="btn btn-dark w-100">
                                <i class="fa fa-check"></i> Đặt hàng
                            </button>
                            <p class="text-muted mt-3 small">
                                <i class="fa fa-info-circle"></i> Chúng tôi sẽ liên hệ xác nhận đơn hàng trong thời gian sớm nhất.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>
