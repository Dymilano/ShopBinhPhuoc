@{
    Layout = "_StoreLayout";
    ViewData["Title"] = "Thanh toán";
    var items = ViewBag.CartItems as IEnumerable<BinhPhuocShop.Models.CartItem> ?? new List<BinhPhuocShop.Models.CartItem>();
    var total = (decimal)(ViewBag.CartTotal ?? 0);
    var error = ViewBag.Error as string;
    var customerName = ViewBag.CustomerName as string ?? "";
    var customerEmail = ViewBag.CustomerEmail as string ?? "";
    var customerPhone = ViewBag.CustomerPhone as string ?? "";
    var customerAddress = ViewBag.CustomerAddress as string ?? "";
}

<div class="bg0 p-t-23 p-b-140">
    <div class="container">
        <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-b-30 p-lr-0-lg">
            <a asp-controller="Home" asp-action="Index" class="stext-109 cl8 hov-cl1 trans-04">Trang chủ<i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i></a>
            <a asp-controller="Cart" asp-action="Index" class="stext-109 cl8 hov-cl1 trans-04">Giỏ hàng<i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i></a>
            <span class="stext-109 cl4">Thanh toán</span>
        </div>

        <h2 class="ltext-103 cl5 p-b-30">Thông tin thanh toán</h2>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger stext-107 p-lr-15 p-tb-10 m-b-20">@error</div>
        }
        <form asp-controller="Checkout" asp-action="Index" method="post">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-lg-8 p-b-30">
                    <div class="p-lr-40 p-t-30 p-b-40 bor10 bg0">
                        <h3 class="stext-101 cl2 p-b-20">Thông tin giao hàng</h3>
                        <div class="bor8 m-b-20">
                            <input type="text" name="customerName" class="stext-111 cl2 plh3 size-116 p-lr-20 p-tb-16" placeholder="Họ và tên *" value="@customerName" required />
                        </div>
                        <div class="bor8 m-b-20">
                            <input type="tel" name="phone" class="stext-111 cl2 plh3 size-116 p-lr-20 p-tb-16" placeholder="Số điện thoại *" value="@customerPhone" required />
                        </div>
                        <div class="bor8 m-b-20">
                            <input type="email" name="email" class="stext-111 cl2 plh3 size-116 p-lr-20 p-tb-16" placeholder="Email" value="@customerEmail" />
                        </div>
                        <div class="bor8 m-b-20">
                            <textarea name="address" class="stext-111 cl2 plh3 size-116 p-lr-20 p-tb-16" rows="3" placeholder="Địa chỉ giao hàng *" required>@customerAddress</textarea>
                        </div>
                        <div class="bor8 m-b-20">
                            <textarea name="note" class="stext-111 cl2 plh3 size-116 p-lr-20 p-tb-16" rows="2" placeholder="Ghi chú về đơn hàng..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 p-b-30">
                    <div class="p-lr-40 p-t-30 p-b-40 bor10 bg0">
                        <h3 class="stext-101 cl2 p-b-20">Đơn hàng của bạn</h3>
                        <div class="flex-w flex-t p-b-20">
                            <ul class="flex-col w-full">
                                @foreach (var item in items)
                                {
                                    <li class="flex-w flex-sb-m p-b-12 stext-107 cl6">
                                        <span>@item.ProductName @(string.IsNullOrEmpty(item.Size) ? "" : "- Size " + item.Size) x @item.Quantity</span>
                                        <span>@item.Amount.ToString("N0")₫</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="flex-w flex-t p-t-20 p-b-20 bor12 stext-101 cl2">
                            <span class="m-r-15">Tổng cộng:</span>
                            <span class="fw-bold">@total.ToString("N0")₫</span>
                        </div>
                        <button type="submit" class="flex-c-m stext-101 cl0 size-116 bg3 bor1 hov-btn3 p-lr-15 trans-04 w-full">
                            <i class="fa fa-check m-r-10"></i> Đặt hàng
                        </button>
                        <p class="stext-107 cl6 p-t-20">
                            <i class="fa fa-info-circle m-r-5"></i> Chúng tôi sẽ liên hệ xác nhận đơn hàng trong thời gian sớm nhất.
                        </p>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
