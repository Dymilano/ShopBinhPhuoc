@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = "Sản phẩm";
    var hexashop = "/hexashop";
    var currentCategory = ViewBag.CurrentCategory as BinhPhuocShop.Models.Category;
    var pageTitle = currentCategory != null ? currentCategory.Name : "Tất cả sản phẩm";
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? new List<dynamic>();
    var brands = ViewBag.Brands as IEnumerable<dynamic> ?? new List<dynamic>();
}

<!-- ***** Products Area Starts ***** -->
<section class="section" id="products">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-heading">
                    <h2>Sản Phẩm Của Chúng Tôi</h2>
                    <span>Xem tất cả sản phẩm của chúng tôi.</span>
                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <div class="row">
            <!-- Filter Sidebar -->
            <div class="col-lg-3">
                <div class="filter-widget">
                    <h4 class="fw-title">Danh mục</h4>
                    <ul class="filter-catagories">
                        <li><a asp-controller="Products" asp-action="Index" class="@(currentCategory == null ? "active" : "")">Tất cả</a></li>
                        @foreach (var cat in categories)
                        {
                            <li><a asp-controller="Collections" asp-action="Index" asp-route-slug="@(cat.Slug ?? "")" class="@(currentCategory?.Id == cat.Id ? "active" : "")">@cat.Name</a></li>
                        }
                    </ul>
                </div>
                <div class="filter-widget">
                    <h4 class="fw-title">Thương hiệu</h4>
                    <ul class="filter-catagories">
                        <li><a asp-controller="Products" asp-action="Index" asp-route-brandId="">Tất cả</a></li>
                        @foreach (var brand in brands)
                        {
                            <li><a asp-controller="Products" asp-action="Index" asp-route-brandId="@brand.Id">@brand.Name</a></li>
                        }
                    </ul>
                </div>
            </div>
            
            <!-- Products Grid -->
            <div class="col-lg-9">
                <!-- Search and Sort -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <form asp-controller="Products" asp-action="Index" method="get" class="d-flex">
                            <input type="hidden" name="categoryId" value="@ViewBag.CategoryId" />
                            <input type="hidden" name="categorySlug" value="@ViewBag.CategorySlug" />
                            <input type="hidden" name="brandId" value="@ViewBag.BrandId" />
                            <input class="form-control me-2" type="text" name="q" value="@ViewBag.Q" placeholder="Tìm kiếm sản phẩm...">
                            <button class="btn btn-outline-dark" type="submit"><i class="fa fa-search"></i></button>
                        </form>
                    </div>
                    <div class="col-md-6 text-end">
                        @{
                            var currentSort = ViewBag.Sort as string ?? "newest";
                            var sortUrl = $"?categoryId={ViewBag.CategoryId}&q={ViewBag.Q}";
                        }
                        <select class="form-select" onchange="window.location.href=this.value" style="display:inline-block;width:auto;">
                            @if (currentSort == "newest")
                            {
                                <option value="@(sortUrl)&sort=newest" selected>Mới nhất</option>
                            }
                            else
                            {
                                <option value="@(sortUrl)&sort=newest">Mới nhất</option>
                            }
                            @if (currentSort == "price-asc")
                            {
                                <option value="@(sortUrl)&sort=price-asc" selected>Giá: Thấp đến cao</option>
                            }
                            else
                            {
                                <option value="@(sortUrl)&sort=price-asc">Giá: Thấp đến cao</option>
                            }
                            @if (currentSort == "price-desc")
                            {
                                <option value="@(sortUrl)&sort=price-desc" selected>Giá: Cao đến thấp</option>
                            }
                            else
                            {
                                <option value="@(sortUrl)&sort=price-desc">Giá: Cao đến thấp</option>
                            }
                        </select>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(ViewBag.Q as string))
                {
                    <div class="alert alert-info">
                        Tìm thấy <strong>@(ViewBag.Total ?? 0)</strong> sản phẩm cho từ khóa "<strong>@ViewBag.Q</strong>"
                    </div>
                }

                <!-- Products Grid - 4 columns per row (4x4 = 16 products per page) -->
                <div class="row products-grid-4">
                    @if (ViewBag.Products != null && ((IEnumerable<dynamic>)ViewBag.Products).Any())
                    {
                        @foreach (var p in (IEnumerable<dynamic>)ViewBag.Products)
                        {
                            var price = p.SalePrice ?? p.Price;
                            var hasSalePrice = p.SalePrice != null && p.SalePrice != p.Price;
                            var oldPrice = hasSalePrice ? p.Price : (decimal?)null;
                            <div class="col-lg-3 col-md-4 col-sm-6 col-6 mb-4">
                                <div class="item" style="transition: all 0.3s ease;">
                                    <div class="thumb" style="position: relative; overflow: hidden; border-radius: 8px; margin-bottom: 15px;">
                                        <div class="hover-content" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(102, 126, 234, 0.9); display: flex; align-items: center; justify-content: center; opacity: 0; transition: all 0.3s ease; z-index: 2;">
                                            <ul style="list-style: none; padding: 0; margin: 0; display: flex; gap: 15px;">
                                                <li>
                                                    <a asp-controller="Products" asp-action="Detail" asp-route-id="@p.Id" style="width: 40px; height: 40px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #667eea; text-decoration: none; transition: all 0.3s ease;">
                                                        <i class="fa fa-eye" style="font-size: 14px;"></i>
                                                    </a>
                                                </li>
                                                <li>
                                                    <a href="#" onclick="addToCart(@p.Id); return false;" style="width: 40px; height: 40px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #667eea; text-decoration: none; transition: all 0.3s ease;">
                                                        <i class="fa fa-shopping-cart" style="font-size: 14px;"></i>
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                        <img src="@(p.ImageUrl ?? hexashop + "/assets/images/men-01.jpg")" alt="@p.Name" style="width: 100%; height: 250px; object-fit: cover; transition: transform 0.3s ease;">
                                    </div>
                                    <div class="down-content" style="text-align: center;">
                                        <h4 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 8px; color: #2a2a2a; min-height: 40px; display: flex; align-items: center; justify-content: center; line-height: 1.3;">
                                            <a asp-controller="Products" asp-action="Detail" asp-route-id="@p.Id" style="color: #2a2a2a; text-decoration: none; transition: color 0.3s ease;">@p.Name</a>
                                        </h4>
                                        <div style="margin-bottom: 8px;">
                                            <span style="font-size: 1.1rem; font-weight: 700; color: #667eea;">@price.ToString("N0")₫</span>
                                            @if (hasSalePrice && oldPrice != null)
                                            {
                                                <span style="text-decoration: line-through; color: #999; margin-left: 5px; font-size: 0.85rem;">@((decimal)oldPrice).ToString("N0")₫</span>
                                            }
                                        </div>
                                        <ul class="stars" style="list-style: none; padding: 0; margin: 0; display: flex; justify-content: center; gap: 2px;">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <li><i class="fa fa-star" style="color: #ffc107; font-size: 11px;"></i></li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="text-center p-5">
                                <i class="fa fa-search" style="font-size: 48px; color: #ccc; margin-bottom: 20px;"></i>
                                <p style="font-size: 18px; color: #999;">Không tìm thấy sản phẩm nào phù hợp</p>
                                <a asp-controller="Products" asp-action="Index" class="btn btn-dark mt-3">Xem tất cả sản phẩm</a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
                {
                    <div class="row">
                        <div class="col-lg-12">
                            <ul class="pagination justify-content-center">
                                @for (var i = 1; i <= (int)ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                                        <a class="page-link" href="?page=@i&categoryId=@ViewBag.CategoryId&categorySlug=@ViewBag.CategorySlug&brandId=@ViewBag.BrandId&q=@ViewBag.Q&sort=@ViewBag.Sort">@i</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
<!-- ***** Products Area Ends ***** -->

@section Scripts {
    <script>
        function addToCart(productId) {
            $.ajax({
                url: '@Url.Action("Add", "Cart")',
                method: 'POST',
                data: {
                    productId: productId,
                    quantity: 1,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.ok) {
                        alert(response.msg || 'Đã thêm vào giỏ hàng');
                        location.reload();
                    } else {
                        alert(response.msg || 'Có lỗi xảy ra');
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra khi thêm vào giỏ hàng');
                }
            });
        }
    </script>
}
