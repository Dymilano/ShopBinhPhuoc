@{
    Layout = "_StoreLayout";
    ViewData["Title"] = "Sản phẩm";
    var currentCategory = ViewBag.CurrentCategory as BinhPhuocShop.Models.Category;
    var pageTitle = currentCategory != null ? currentCategory.Name : "Tất cả sản phẩm";
    var store = "/store";
    var categories = ViewBag.Categories as IEnumerable<dynamic> ?? new List<dynamic>();
}

<!-- Product -->
<div class="bg0 m-t-23 p-b-140">
    <div class="container">
        <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
            <a asp-controller="Home" asp-action="Index" class="stext-109 cl8 hov-cl1 trans-04">
                Trang chủ
                <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
            </a>
            @if (currentCategory != null)
            {
                <span class="stext-109 cl4">
                    @currentCategory.Name
                </span>
            }
            else
            {
                <span class="stext-109 cl4">Sản phẩm</span>
            }
        </div>

        <div class="flex-w flex-sb-m p-b-52">
            <div class="flex-w flex-l-m filter-tope-group m-tb-10">
                <a asp-controller="Products" asp-action="Index" class="stext-106 cl6 hov1 bor3 trans-04 m-r-32 m-tb-5 @(currentCategory == null ? "how-active1" : "")" data-filter="*">
                    Tất cả
                </a>
                @if (categories != null && categories.Any())
                {
                    @foreach (var c in categories)
                    {
                        <a asp-controller="Collections" asp-action="Index" asp-route-slug="@(c.Slug ?? "")" class="stext-106 cl6 hov1 bor3 trans-04 m-r-32 m-tb-5 @(currentCategory?.Id == c.Id ? "how-active1" : "")" data-filter="@(c.Slug ?? "")">
                            @c.Name
                        </a>
                    }
                }
            </div>

            <div class="flex-w flex-c-m m-tb-10">
                <div class="flex-c-m stext-106 cl6 size-104 bor4 pointer hov-btn3 trans-04 m-r-8 m-tb-4 js-show-filter">
                    <i class="icon-filter cl2 m-r-6 fs-15 trans-04 zmdi zmdi-filter-list"></i>
                    <i class="icon-close-filter cl2 m-r-6 fs-15 trans-04 zmdi zmdi-close dis-none"></i>
                    Lọc
                </div>

                <div class="flex-c-m stext-106 cl6 size-105 bor4 pointer hov-btn3 trans-04 m-tb-4 js-show-search">
                    <i class="icon-search cl2 m-r-6 fs-15 trans-04 zmdi zmdi-search"></i>
                    <i class="icon-close-search cl2 m-r-6 fs-15 trans-04 zmdi zmdi-close dis-none"></i>
                    Tìm kiếm
                </div>
            </div>
            
            <!-- Search product -->
            <div class="dis-none panel-search w-full p-t-10 p-b-15">
                <form asp-controller="Products" asp-action="Index" method="get" class="bor8 dis-flex p-l-15">
                    <button type="submit" class="size-113 flex-c-m fs-16 cl2 hov-cl1 trans-04">
                        <i class="zmdi zmdi-search"></i>
                    </button>
                    <input class="mtext-107 cl2 size-114 plh2 p-r-15" type="text" name="q" value="@ViewBag.Q" placeholder="Tìm kiếm sản phẩm...">
                </form>	
            </div>

            <!-- Filter -->
            <div class="dis-none panel-filter w-full p-t-10">
                <div class="wrap-filter flex-w bg6 w-full p-lr-40 p-t-27 p-lr-15-sm">
                    <div class="filter-col1 p-r-15 p-b-27">
                        <div class="mtext-102 cl2 p-b-15">
                            Sắp xếp
                        </div>
                        <ul>
                            <li class="p-b-6">
                                <a href="?sort=default" class="filter-link stext-106 trans-04 @(ViewBag.Sort == "default" || ViewBag.Sort == null ? "filter-link-active" : "")">
                                    Mặc định
                                </a>
                            </li>
                            <li class="p-b-6">
                                <a href="?sort=popularity" class="filter-link stext-106 trans-04 @(ViewBag.Sort == "popularity" ? "filter-link-active" : "")">
                                    Phổ biến
                                </a>
                            </li>
                            <li class="p-b-6">
                                <a href="?sort=price-asc" class="filter-link stext-106 trans-04 @(ViewBag.Sort == "price-asc" ? "filter-link-active" : "")">
                                    Giá: Thấp đến cao
                                </a>
                            </li>
                            <li class="p-b-6">
                                <a href="?sort=price-desc" class="filter-link stext-106 trans-04 @(ViewBag.Sort == "price-desc" ? "filter-link-active" : "")">
                                    Giá: Cao đến thấp
                                </a>
                            </li>
                            <li class="p-b-6">
                                <a href="?sort=newest" class="filter-link stext-106 trans-04 @(ViewBag.Sort == "newest" ? "filter-link-active" : "")">
                                    Mới nhất
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Q as string))
        {
            <div class="p-b-20">
                <p class="stext-107 cl6">Tìm thấy <strong>@(ViewBag.Total ?? 0)</strong> sản phẩm cho từ khóa "<strong>@ViewBag.Q</strong>"</p>
            </div>
        }

        <div class="row isotope-grid">
            @if (ViewBag.Products != null && ((IEnumerable<dynamic>)ViewBag.Products).Any())
            {
                @foreach (var p in (IEnumerable<dynamic>)ViewBag.Products)
                {
                    <div class="col-sm-6 col-md-4 col-lg-3 p-b-35 isotope-item @(p.Category?.Slug ?? "")">
                        <div class="block2">
                            <div class="block2-pic hov-img0">
                                <img src="@(p.ImageUrl ?? store + "/images/product-01.jpg")" alt="@p.Name">
                                <a asp-controller="Products" asp-action="Detail" asp-route-id="@p.Id" class="block2-btn flex-c-m stext-103 cl2 size-102 bg0 bor2 hov-btn1 p-lr-15 trans-04">
                                    Xem
                                </a>
                            </div>
                            <div class="block2-txt flex-w flex-t p-t-14">
                                <div class="block2-txt-child1 flex-col-l">
                                    <a asp-controller="Products" asp-action="Detail" asp-route-id="@p.Id" class="stext-104 cl4 hov-cl1 trans-04 js-name-b2 p-b-6">
                                        @p.Name
                                    </a>
                                    <span class="stext-105 cl3">
                                        @((p.SalePrice ?? p.Price).ToString("N0"))₫
                                        @if (p.SalePrice != null && (decimal)p.SalePrice < (decimal)p.Price)
                                        {
                                            <del class="stext-106 cl6">@(((decimal)p.Price).ToString("N0"))₫</del>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="text-center p-t-60 p-b-60">
                        <i class="fa fa-search" style="font-size: 48px; color: #ccc; margin-bottom: 20px;"></i>
                        <p class="stext-107 cl6" style="font-size: 18px;">Không tìm thấy sản phẩm nào phù hợp</p>
                        <p class="stext-107 cl6 p-t-10">
                            <a asp-controller="Products" asp-action="Index" class="stext-101 cl2 hov-cl1">Xem tất cả sản phẩm</a>
                        </p>
                    </div>
                </div>
            }
        </div>

        @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
        {
            <!-- Pagination -->
            <div class="flex-c-m flex-w w-full p-t-38">
                @for (var i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <a href="?page=@i&categoryId=@ViewBag.CategoryId&categorySlug=@ViewBag.CategorySlug&brandId=@ViewBag.BrandId&q=@ViewBag.Q&sort=@ViewBag.Sort" class="flex-c-m how-pagination1 trans-04 m-all-7 @(i == (int)ViewBag.Page ? "active-pagination1" : "")">
                        @i
                    </a>
                }
            </div>
        }
    </div>
</div>
