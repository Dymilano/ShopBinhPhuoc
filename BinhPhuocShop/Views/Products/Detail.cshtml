@model BinhPhuocShop.Models.Product
@using System.Text.Json
@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = Model.Name;
    var hexashop = "/hexashop";
    var imageUrls = new List<string>();
    if (!string.IsNullOrEmpty(Model.ImageUrl)) imageUrls.Add(Model.ImageUrl);
    if (!string.IsNullOrEmpty(Model.ImageUrls))
    {
        try
        {
            var extra = JsonSerializer.Deserialize<string[]>(Model.ImageUrls);
            if (extra != null) foreach (var u in extra) { if (!string.IsNullOrEmpty(u) && !imageUrls.Contains(u)) imageUrls.Add(u); }
        }
        catch { }
    }
    imageUrls = imageUrls.Take(5).ToList();
    if (imageUrls.Count == 0) imageUrls.Add(hexashop + "/assets/images/single-product-01.jpg");
    var currentPrice = Model.SalePrice ?? Model.Price;
    var hasSale = Model.SalePrice.HasValue && Model.SalePrice < Model.Price;
    var related = ViewBag.Related as IEnumerable<dynamic> ?? new List<dynamic>();
}

<!-- ***** Product Area Starts ***** -->
<section class="section" id="product">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="left-images">
                    @foreach (var img in imageUrls)
                    {
                        <img src="@img" alt="@Model.Name" style="width: 100%; margin-bottom: 20px;">
                    }
                </div>
            </div>
            <div class="col-lg-4">
                <div class="right-content">
                    <h4>@Model.Name</h4>
                    <span class="price">@currentPrice.ToString("N0")₫</span>
                    @if (hasSale)
                    {
                        <span style="text-decoration: line-through; color: #999; margin-left: 10px;">@Model.Price.ToString("N0")₫</span>
                    }
                    <ul class="stars">
                        @for (int i = 0; i < 5; i++)
                        {
                            <li><i class="fa fa-star"></i></li>
                        }
                    </ul>
                    @if (!string.IsNullOrEmpty(Model.ShortDescription))
                    {
                        <span>@Model.ShortDescription</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="quote">
                            <i class="fa fa-quote-left"></i><p>@Model.Description</p>
                        </div>
                    }
                    @if (Model.Brand != null || !string.IsNullOrEmpty(Model.Sku))
                    {
                        <p class="mt-3">
                            @if (Model.Brand != null) { <strong>Thương hiệu:</strong> @Model.Brand.Name<br> }
                            @if (!string.IsNullOrEmpty(Model.Sku)) { <strong>MSP:</strong> @Model.Sku<br> }
                            <strong>Tồn kho:</strong> @Model.Stock sản phẩm
                        </p>
                    }
                    <div class="quantity-content">
                        <div class="left-content">
                            <h6>Số lượng</h6>
                        </div>
                        <div class="right-content">
                            <div class="quantity buttons_added">
                                <input type="button" value="-" class="minus" onclick="decreaseQuantity()">
                                <input type="number" step="1" min="1" max="@Model.Stock" name="quantity" id="product-quantity" value="1" title="Qty" class="input-text qty text" size="4">
                                <input type="button" value="+" class="plus" onclick="increaseQuantity()">
                            </div>
                        </div>
                    </div>
                    <div class="total">
                        <h4>Tổng: <span id="total-price">@currentPrice.ToString("N0")</span>₫</h4>
                        <div class="main-border-button">
                            <a href="#" onclick="addToCart(@Model.Id); return false;">Thêm vào giỏ hàng</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Product Area Ends ***** -->

@if (related.Any())
{
    <!-- ***** Related Products Area Starts ***** -->
    <section class="section" id="related">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="section-heading">
                        <h2>Sản Phẩm Liên Quan</h2>
                        <span>Các sản phẩm tương tự bạn có thể thích</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="men-item-carousel">
                        <div class="owl-men-item owl-carousel">
                            @foreach (var product in related)
                            {
                                var price = product.SalePrice ?? product.Price;
                                var hasSalePrice = product.SalePrice != null && product.SalePrice != product.Price;
                                var oldPrice = hasSalePrice ? product.Price : (decimal?)null;
                                <div class="item">
                                    <div class="thumb">
                                        <div class="hover-content">
                                            <ul>
                                                <li><a asp-controller="Products" asp-action="Detail" asp-route-id="@product.Id"><i class="fa fa-eye"></i></a></li>
                                                <li><a href="#" onclick="addToCart(@product.Id); return false;"><i class="fa fa-shopping-cart"></i></a></li>
                                            </ul>
                                        </div>
                                        <img src="@(product.ImageUrl ?? hexashop + "/assets/images/men-01.jpg")" alt="@product.Name">
                                    </div>
                                    <div class="down-content">
                                        <h4>@product.Name</h4>
                                        <span>@price.ToString("N0")₫</span>
                                        @if (hasSalePrice && oldPrice != null)
                                        {
                                            <span style="text-decoration: line-through; color: #999; margin-left: 10px; font-size: 14px;">@((decimal)oldPrice).ToString("N0")₫</span>
                                        }
                                        <ul class="stars">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <li><i class="fa fa-star"></i></li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- ***** Related Products Area Ends ***** -->
}

@section Scripts {
    <script src="@(hexashop)/assets/js/quantity.js"></script>
    <script>
        var productPrice = @currentPrice;
        var maxStock = @Model.Stock;
        
        function increaseQuantity() {
            var qtyInput = document.getElementById('product-quantity');
            var currentQty = parseInt(qtyInput.value) || 1;
            if (currentQty < maxStock) {
                qtyInput.value = currentQty + 1;
                updateTotal();
            }
        }
        
        function decreaseQuantity() {
            var qtyInput = document.getElementById('product-quantity');
            var currentQty = parseInt(qtyInput.value) || 1;
            if (currentQty > 1) {
                qtyInput.value = currentQty - 1;
                updateTotal();
            }
        }
        
        function updateTotal() {
            var qty = parseInt(document.getElementById('product-quantity').value) || 1;
            var total = productPrice * qty;
            document.getElementById('total-price').textContent = total.toLocaleString('vi-VN');
        }
        
        document.getElementById('product-quantity').addEventListener('change', function() {
            var qty = parseInt(this.value) || 1;
            if (qty < 1) this.value = 1;
            if (qty > maxStock) {
                this.value = maxStock;
                alert('Số lượng tối đa là ' + maxStock);
            }
            updateTotal();
        });
        
        function addToCart(productId) {
            var size = document.getElementById('product-size') ? document.getElementById('product-size').value : '';
            var quantity = parseInt(document.getElementById('product-quantity').value) || 1;
            
            $.ajax({
                url: '@Url.Action("Add", "Cart")',
                method: 'POST',
                data: {
                    productId: productId,
                    size: size,
                    quantity: quantity,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.ok) {
                        alert(response.msg || 'Đã thêm vào giỏ hàng');
                        location.reload();
                    } else {
                        alert(response.msg || 'Có lỗi xảy ra');
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra khi thêm vào giỏ hàng');
                }
            });
        }
    </script>
}
