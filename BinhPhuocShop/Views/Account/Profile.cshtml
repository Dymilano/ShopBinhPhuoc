@model BinhPhuocShop.Models.User
@{
    Layout = "_StoreLayout";
    ViewData["Title"] = "Thông tin cá nhân";
    var success = TempData["Success"] as string;
    var error = TempData["Error"] as string;
    var store = "/store";
}

<section class="bg-img1 txt-center p-lr-15 p-tb-92" style="background-image: url('@(store)/images/bg-01.jpg'); background-color: #f5f5f5;">
    <h2 class="ltext-105 cl0 txt-center">Thông tin cá nhân</h2>
</section>

<section class="bg0 p-t-60 p-b-80">
    <div class="container">
        <div class="bread-crumb flex-w p-l-25 p-r-15 p-b-30 p-lr-0-lg">
            <a asp-controller="Home" asp-action="Index" class="stext-109 cl8 hov-cl1 trans-04">Trang chủ <i class="fa fa-angle-right m-l-9 m-r-10"></i></a>
            <span class="stext-109 cl4">Thông tin cá nhân</span>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                @if (!string.IsNullOrEmpty(success))
                {
                    <div class="alert alert-success">@success</div>
                }
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                <div class="card mb-4" style="border-radius: 8px; border: 1px solid #e5e5e5;">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Cập nhật thông tin</h5>
                        <form asp-action="UpdateProfile" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label">Họ tên</label>
                                <input type="text" name="name" class="form-control" value="@Model.Name" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" value="@Model.Email" readonly disabled />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số điện thoại</label>
                                <input type="tel" name="phone" class="form-control" value="@Model.Phone" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Địa chỉ</label>
                                <input type="text" name="address" class="form-control" value="@Model.Address" />
                            </div>
                            <button type="submit" class="btn btn-dark">Lưu thay đổi</button>
                        </form>
                    </div>
                </div>
                <div class="card" style="border-radius: 8px; border: 1px solid #e5e5e5;">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Đổi mật khẩu</h5>
                        <form asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label">Mật khẩu hiện tại</label>
                                <input type="password" name="currentPassword" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Mật khẩu mới</label>
                                <input type="password" name="newPassword" class="form-control" required minlength="6" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Xác nhận mật khẩu mới</label>
                                <input type="password" name="confirmPassword" class="form-control" required />
                            </div>
                            <button type="submit" class="btn btn-outline-dark">Đổi mật khẩu</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
