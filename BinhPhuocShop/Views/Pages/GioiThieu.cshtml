@{
    Layout = "_HexashopLayout";
    ViewData["Title"] = "Giới thiệu";
    var hexashop = "/hexashop";
    var productCategories = ViewBag.ProductCategories as IEnumerable<BinhPhuocShop.Models.Category> ?? new List<BinhPhuocShop.Models.Category>();
    var categoryProductCounts = ViewBag.CategoryProductCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<!-- Page Title -->
<div class="container mt-4 mb-4">
    <div class="row">
        <div class="col-lg-12">
            <h2 class="fw-bold" style="color: #2a2a2a; font-size: 2rem;">Giới thiệu</h2>
        </div>
    </div>
</div>

<!-- ***** About Shop Area Starts ***** -->
<section class="section" id="about-shop">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="left-image">
                    <img src="@(hexashop)/assets/images/about-left-image.jpg" alt="Bình Phước Shop" class="img-fluid rounded shadow" style="width: 100%; height: auto; object-fit: cover;">
                </div>
            </div>
            <div class="col-lg-6">
                <div class="right-content">
                    <h3 class="mb-3 fw-bold">Về Bình Phước Shop</h3>
                    <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.8;">
                        <strong>Bình Phước Shop</strong> là thương hiệu chuyên kinh doanh, phân phối giày dép chất lượng cao với đa dạng các sản phẩm từ giày nam, giày nữ đến dép nam, dép nữ và các phụ kiện thời trang.
                    </p>
                    <div class="quote mb-4" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); padding: 30px; border-left: 4px solid #667eea; border-radius: 8px;">
                        <i class="fa fa-quote-left" style="font-size: 28px; color: #667eea; margin-bottom: 15px; display: block;"></i>
                        <p class="mb-0" style="font-style: italic; color: #555; font-size: 1.05rem; line-height: 1.8;">
                            Với nhiều năm kinh nghiệm trong ngành, chúng tôi cam kết mang đến cho khách hàng những sản phẩm chất lượng cao, nhiều bộ sưu tập độc đáo và dịch vụ chăm sóc khách hàng tận tâm. Mọi sản phẩm đều được chăm chút tỉ mỉ, trải nghiệm mua sắm và dịch vụ hậu mãi luôn hướng tới sự hài lòng của khách hàng.
                        </p>
                    </div>
                    <p class="mb-4" style="line-height: 1.8;">
                        Bình Phước Shop ra đời với tinh thần mang đến sản phẩm giày dép chất lượng, thiết kế gọn gàng, đẳng cấp. Chúng tôi không ngừng cập nhật những xu hướng thời trang mới nhất, đảm bảo khách hàng luôn có những lựa chọn phù hợp với phong cách và nhu cầu của mình.
                    </p>
                    <div class="social-links">
                        <h6 class="mb-3 fw-semibold">Theo dõi chúng tôi:</h6>
                        <ul style="list-style: none; padding: 0; display: flex; gap: 15px;">
                            <li><a href="#" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; background: #667eea; color: #fff; border-radius: 50%; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);"><i class="fa fa-facebook"></i></a></li>
                            <li><a href="#" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; background: #667eea; color: #fff; border-radius: 50%; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);"><i class="fa fa-twitter"></i></a></li>
                            <li><a href="#" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; background: #667eea; color: #fff; border-radius: 50%; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);"><i class="fa fa-linkedin"></i></a></li>
                            <li><a href="#" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; background: #667eea; color: #fff; border-radius: 50%; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);"><i class="fa fa-instagram"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** About Shop Area Ends ***** -->

<!-- ***** Product Categories Introduction Starts ***** -->
<section class="section" id="product-categories" style="background-color: #f8f9fa;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-heading">
                    <h2>Sản Phẩm Của Chúng Tôi</h2>
                    <span>Khám phá các bộ sưu tập đa dạng từ Bình Phước Shop</span>
                </div>
            </div>
        </div>
        <div class="container">
            <div class="row">
                @{
                    var categoryInfo = new Dictionary<string, (string Title, string Description, string Icon)>
                    {
                        { "giay-nam", ("Giày Nam", "Bộ sưu tập giày nam đa dạng với thiết kế hiện đại, sang trọng. Từ giày thể thao năng động đến giày da công sở lịch lãm, chúng tôi mang đến những lựa chọn hoàn hảo cho phái mạnh.", "fa fa-male") },
                        { "giay-nu", ("Giày Nữ", "Bộ sưu tập giày nữ thời thượng với nhiều phong cách khác nhau. Từ giày cao gót thanh lịch đến giày thể thao năng động, giúp bạn tự tin tỏa sáng mọi lúc mọi nơi.", "fa fa-female") },
                        { "dep-nam", ("Dép Nam", "Dép nam chất lượng cao với thiết kế thoải mái, bền đẹp. Phù hợp cho mọi hoạt động từ đi chơi, thể thao đến công sở, mang lại cảm giác dễ chịu suốt cả ngày.", "fa fa-male") },
                        { "dep-nu", ("Dép Nữ", "Dép nữ đa dạng mẫu mã với thiết kế nữ tính, hiện đại. Từ dép quai hậu tiện lợi đến dép cao gót sang trọng, giúp bạn luôn nổi bật và tự tin.", "fa fa-female") }
                    };
                }
                
                @foreach (var category in productCategories.OrderBy(c => c.DisplayOrder))
                {
                    var slug = category.Slug ?? "";
                    var info = categoryInfo.ContainsKey(slug) ? categoryInfo[slug] : (category.Name, category.Description ?? "Sản phẩm chất lượng cao", "fa fa-shopping-bag");
                    var productCount = categoryProductCounts.ContainsKey(slug) ? categoryProductCounts[slug] : 0;
                    var infoTitle = info.Item1;
                    var infoDescription = info.Item2;
                    var infoIcon = info.Item3;
                    
                    <div class="col-lg-6 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm" style="border: none; transition: all 0.3s ease;">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-start mb-3">
                                    <div class="icon-box me-3" style="width: 60px; height: 60px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                        <i class="@infoIcon" style="font-size: 28px; color: #fff;"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h4 class="mb-2 fw-bold">@infoTitle</h4>
                                        @if (productCount > 0)
                                        {
                                            <span class="badge" style="background: #667eea; color: #fff; padding: 5px 12px; border-radius: 20px; font-size: 0.85rem;">
                                                @productCount sản phẩm
                                            </span>
                                        }
                                    </div>
                                </div>
                                <p class="mb-3" style="line-height: 1.8; color: #555;">
                                    @infoDescription
                                </p>
                                <a asp-controller="Collections" asp-action="Index" asp-route-slug="@slug" class="btn btn-outline-dark btn-sm">
                                    <i class="fa fa-arrow-right me-2"></i>Xem sản phẩm
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
<!-- ***** Product Categories Introduction Ends ***** -->

<!-- ***** Features Area Starts ***** -->
<section class="section" id="features">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-heading">
                    <h2>Tại sao chọn Bình Phước Shop?</h2>
                    <span>Những điểm khác biệt của chúng tôi</span>
                </div>
            </div>
        </div>
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="feature-item text-center card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="icon mb-3">
                                <i class="fa fa-check-circle" style="font-size: 48px; color: #667eea;"></i>
                            </div>
                            <h4 class="mb-3">Chất lượng cao</h4>
                            <p class="mb-0">Sản phẩm chính hãng, chất lượng đảm bảo, được kiểm tra kỹ lưỡng trước khi đến tay khách hàng</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="feature-item text-center card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="icon mb-3">
                                <i class="fa fa-truck" style="font-size: 48px; color: #667eea;"></i>
                            </div>
                            <h4 class="mb-3">Giao hàng nhanh</h4>
                            <p class="mb-0">Miễn phí vận chuyển đơn hàng trên 1.000.000₫, giao hàng toàn quốc với thời gian nhanh chóng</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="feature-item text-center card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="icon mb-3">
                                <i class="fa fa-shield" style="font-size: 48px; color: #667eea;"></i>
                            </div>
                            <h4 class="mb-3">Bảo hành</h4>
                            <p class="mb-0">Chính sách bảo hành rõ ràng, minh bạch, đổi trả trong 7 ngày nếu sản phẩm lỗi</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="feature-item text-center card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="icon mb-3">
                                <i class="fa fa-headset" style="font-size: 48px; color: #667eea;"></i>
                            </div>
                            <h4 class="mb-3">Hỗ trợ 24/7</h4>
                            <p class="mb-0">Đội ngũ tư vấn chuyên nghiệp, nhiệt tình, sẵn sàng hỗ trợ khách hàng mọi lúc mọi nơi</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Features Area Ends ***** -->

<!-- ***** Stats Area Starts ***** -->
<section class="section" id="stats" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff;">
    <div class="container">
        <div class="row">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <h2 class="counter mb-2" style="color: #fff; font-size: 3rem; font-weight: 700;">1000+</h2>
                    <p style="color: rgba(255,255,255,0.9); font-size: 1.1rem; font-weight: 500;">Sản phẩm</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <h2 class="counter mb-2" style="color: #fff; font-size: 3rem; font-weight: 700;">5000+</h2>
                    <p style="color: rgba(255,255,255,0.9); font-size: 1.1rem; font-weight: 500;">Khách hàng</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <h2 class="counter mb-2" style="color: #fff; font-size: 3rem; font-weight: 700;">10+</h2>
                    <p style="color: rgba(255,255,255,0.9); font-size: 1.1rem; font-weight: 500;">Năm kinh nghiệm</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <h2 class="counter mb-2" style="color: #fff; font-size: 3rem; font-weight: 700;">100%</h2>
                    <p style="color: rgba(255,255,255,0.9); font-size: 1.1rem; font-weight: 500;">Hài lòng</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Stats Area Ends ***** -->

<!-- ***** Mission & Vision Area Starts ***** -->
<section class="section" id="mission-vision" style="background-color: #fff;">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="card h-100 shadow-sm" style="border: none;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box me-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa fa-bullseye" style="font-size: 24px; color: #fff;"></i>
                            </div>
                            <h4 class="mb-0 fw-bold">Sứ mệnh</h4>
                        </div>
                        <p style="line-height: 1.8; color: #555;">
                            Bình Phước Shop cam kết mang đến cho khách hàng những sản phẩm giày dép chất lượng cao với giá cả hợp lý. Chúng tôi không ngừng nỗ lực để trở thành địa chỉ tin cậy cho mọi nhu cầu về giày dép, từ những sản phẩm hàng ngày đến những bộ sưu tập đặc biệt.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100 shadow-sm" style="border: none;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="icon-box me-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa fa-eye" style="font-size: 24px; color: #fff;"></i>
                            </div>
                            <h4 class="mb-0 fw-bold">Tầm nhìn</h4>
                        </div>
                        <p style="line-height: 1.8; color: #555;">
                            Trở thành thương hiệu giày dép hàng đầu tại Việt Nam, được khách hàng tin tưởng và yêu mến. Chúng tôi hướng tới việc mở rộng hệ thống cửa hàng trên toàn quốc và phát triển các kênh bán hàng trực tuyến để phục vụ khách hàng tốt hơn.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Mission & Vision Area Ends ***** -->

@section Scripts {
    <script>
        // Counter animation
        $(document).ready(function() {
            $('.counter').each(function() {
                var $this = $(this);
                var countTo = $this.text().replace(/[^0-9]/g, '');
                $({ countNum: 0 }).animate({
                    countNum: countTo
                }, {
                    duration: 2000,
                    easing: 'swing',
                    step: function() {
                        $this.text(Math.floor(this.countNum) + ($this.text().includes('%') ? '%' : '+'));
                    },
                    complete: function() {
                        $this.text($this.text());
                    }
                });
            });
        });
        
        // Card hover effect
        $(document).ready(function() {
            $('.card').hover(
                function() {
                    $(this).css('transform', 'translateY(-5px)');
                },
                function() {
                    $(this).css('transform', 'translateY(0)');
                }
            );
        });
    </script>
}
