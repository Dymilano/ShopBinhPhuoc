@{
    ViewData["Title"] = "Quản lý ảnh trang chủ";
}
<div class="flex flex-row justify-between items-center mb-6">
    <h5 class="text-gray-800 font-semibold m-0">Quản lý ảnh trang chủ</h5>
    <a href="@Url.Action("Index", "Home", new { area = "" })" target="_blank" class="text-sm text-teal-600 hover:text-teal-700">
        <i class="fad fa-external-link mr-1"></i>Xem trang chủ
    </a>
</div>

@if (TempData["Message"] != null)
{
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">@TempData["Message"]</div>
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Ảnh Background Hero Section -->
    <div class="card">
        <div class="card-header">
            <h6 class="text-gray-800 font-semibold">1. Ảnh Background (Hero Section)</h6>
        </div>
        <div class="card-body">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Ảnh hiện tại:</label>
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                    <img src="@ViewBag.HeroBackground" alt="Hero Background" class="w-full h-48 object-cover" onerror="this.src='/hexashop/assets/images/left-banner-image.jpg'" />
                </div>
            </div>
            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="imageType" value="HeroBackground" />
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Chọn ảnh mới:</label>
                    <input type="file" name="imageFile" accept="image/*" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" required />
                    <p class="text-xs text-gray-500 mt-1">Kích thước khuyến nghị: 1920x600px hoặc lớn hơn</p>
                </div>
                <button type="submit" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-medium py-2 px-4 rounded-md transition duration-200">
                    <i class="fad fa-upload mr-2"></i>Cập nhật ảnh
                </button>
            </form>
        </div>
    </div>

    <!-- Ảnh Giày Nam -->
    <div class="card">
        <div class="card-header">
            <h6 class="text-gray-800 font-semibold">2. Ảnh Giày Nam</h6>
        </div>
        <div class="card-body">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Ảnh hiện tại:</label>
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                    <img src="@ViewBag.BannerGiayNam" alt="Giày Nam" class="w-full h-48 object-cover" onerror="this.src='/hexashop/assets/images/baner-right-image-01.jpg'" />
                </div>
            </div>
            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="imageType" value="BannerGiayNam" />
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Chọn ảnh mới:</label>
                    <input type="file" name="imageFile" accept="image/*" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" required />
                    <p class="text-xs text-gray-500 mt-1">Kích thước khuyến nghị: 600x400px hoặc lớn hơn</p>
                </div>
                <button type="submit" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-medium py-2 px-4 rounded-md transition duration-200">
                    <i class="fad fa-upload mr-2"></i>Cập nhật ảnh
                </button>
            </form>
        </div>
    </div>

    <!-- Ảnh Giày Nữ -->
    <div class="card">
        <div class="card-header">
            <h6 class="text-gray-800 font-semibold">3. Ảnh Giày Nữ</h6>
        </div>
        <div class="card-body">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Ảnh hiện tại:</label>
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                    <img src="@ViewBag.BannerGiayNu" alt="Giày Nữ" class="w-full h-48 object-cover" onerror="this.src='/hexashop/assets/images/baner-right-image-02.jpg'" />
                </div>
            </div>
            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="imageType" value="BannerGiayNu" />
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Chọn ảnh mới:</label>
                    <input type="file" name="imageFile" accept="image/*" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" required />
                    <p class="text-xs text-gray-500 mt-1">Kích thước khuyến nghị: 600x400px hoặc lớn hơn</p>
                </div>
                <button type="submit" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-medium py-2 px-4 rounded-md transition duration-200">
                    <i class="fad fa-upload mr-2"></i>Cập nhật ảnh
                </button>
            </form>
        </div>
    </div>

    <!-- Ảnh Dép Nam -->
    <div class="card">
        <div class="card-header">
            <h6 class="text-gray-800 font-semibold">4. Ảnh Dép Nam</h6>
        </div>
        <div class="card-body">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Ảnh hiện tại:</label>
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                    <img src="@ViewBag.BannerDepNam" alt="Dép Nam" class="w-full h-48 object-cover" onerror="this.src='/hexashop/assets/images/baner-right-image-03.jpg'" />
                </div>
            </div>
            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="imageType" value="BannerDepNam" />
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Chọn ảnh mới:</label>
                    <input type="file" name="imageFile" accept="image/*" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" required />
                    <p class="text-xs text-gray-500 mt-1">Kích thước khuyến nghị: 600x400px hoặc lớn hơn</p>
                </div>
                <button type="submit" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-medium py-2 px-4 rounded-md transition duration-200">
                    <i class="fad fa-upload mr-2"></i>Cập nhật ảnh
                </button>
            </form>
        </div>
    </div>
</div>

<div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
    <p class="text-sm text-blue-800">
        <i class="fad fa-info-circle mr-2"></i>
        <strong>Lưu ý:</strong> Sau khi cập nhật ảnh, vui lòng refresh trang chủ để xem thay đổi. 
        Ảnh sẽ được lưu vào thư mục <code>/uploads/home-images/</code> và tự động thay thế ảnh cũ.
    </p>
</div>
