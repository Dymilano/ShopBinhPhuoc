@model IEnumerable<SiteSetting>
@{
    ViewData["Title"] = "Cài đặt web";
}

@section PageHeaderRight {
    <button type="submit" form="settingsForm" class="btn btn-primary">
        <i class="feather-save me-2"></i>
        <span>Lưu cài đặt</span>
    </button>
}

<div class="row">
    <div class="col-lg-12">
        <div class="card border-top-0">
            <div class="card-header p-0">
                <ul class="nav nav-tabs flex-wrap w-100 text-center" id="settingsTabs" role="tablist">
                    <li class="nav-item flex-fill border-top" role="presentation">
                        <a href="javascript:void(0);" class="nav-link active" data-bs-toggle="tab" data-bs-target="#generalTab" role="tab">Cài đặt cơ bản</a>
                    </li>
                    <li class="nav-item flex-fill border-top" role="presentation">
                        <a href="javascript:void(0);" class="nav-link" data-bs-toggle="tab" data-bs-target="#imagesTab" role="tab">Hình ảnh & Banner</a>
                    </li>
                </ul>
            </div>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="generalTab" role="tabpanel">
                    <form id="settingsForm" asp-action="Save" method="post" enctype="multipart/form-data">
                        <div class="admin-form">
                            @Html.AntiForgeryToken()
                            <h3 class="form-title">Cài đặt website</h3>
                            @foreach (var s in Model.Where(x => !x.Key.StartsWith("Banner") && !x.Key.StartsWith("Video")))
                            {
                                <div class="form-row">
                                    <label>@s.Key</label>
                                    <input type="text" name="values[@s.Key]" value="@s.Value" placeholder="@s.Key">
                                </div>
                            }
                            <hr class="my-4">
                            <div class="form-row">
                                <label>Thêm cài đặt mới (Key)</label>
                                <input type="text" name="newKey" placeholder="Key (VD: SiteName)">
                            </div>
                            <div class="form-row">
                                <label>Thêm cài đặt mới (Value)</label>
                                <input type="text" name="newValue" placeholder="Value">
                            </div>
                            <div class="form-actions">
                                <button type="submit">
                                    <i class="feather-save me-2"></i>
                                    <span>Lưu thay đổi</span>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="tab-pane fade" id="imagesTab" role="tabpanel">
                    <div class="card-body">
                        <!-- Upload Banner/Video chung -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3">
                                <span class="d-block mb-1">Tải lên Banner/Video:</span>
                                <span class="fs-11 fw-normal text-muted">Hỗ trợ: JPG, PNG, GIF, MP4, WebM</span>
                            </h6>
                            <form asp-action="UploadBanner" method="post" enctype="multipart/form-data" id="banner-form">
                                @Html.AntiForgeryToken()
                                <div class="row g-2 mb-2">
                                    <div class="col-lg-4">
                                        <label class="fw-semibold mb-1 d-block fs-12">File (Ảnh/GIF/Video): </label>
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-text"><i class="feather-upload"></i></div>
                                            <input type="file" name="bannerFile" accept="image/*,video/*,.gif" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-lg-3">
                                        <label class="fw-semibold mb-1 d-block fs-12">Loại banner: </label>
                                        <select name="bannerType" class="form-select form-select-sm">
                                            <option value="home">Trang chủ</option>
                                            <option value="promotion">Khuyến mãi</option>
                                            <option value="monthly">Theo tháng</option>
                                        </select>
                                    </div>
                                    <div class="col-lg-5">
                                        <label class="fw-semibold mb-1 d-block fs-12">Link (tùy chọn): </label>
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-text"><i class="feather-link"></i></div>
                                            <input type="text" name="bannerLink" placeholder="https://..." class="form-control">
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-lg-12">
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            <i class="feather-upload me-2"></i>
                                            <span>Tải lên Banner</span>
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <hr class="my-3">
                        <!-- Quản lý 4 ảnh chính trang chủ -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3">
                                <span class="d-block mb-1">4 Ảnh Chính Trang Chủ:</span>
                                <span class="fs-11 fw-normal text-muted">Quản lý các ảnh hiển thị trên trang chủ</span>
                            </h6>
                            <div class="row g-3">
                                @{
                                    var heroBg = Model.FirstOrDefault(x => x.Key == "HeroBackground");
                                    var bannerGiayNam = Model.FirstOrDefault(x => x.Key == "BannerGiayNam");
                                    var bannerGiayNu = Model.FirstOrDefault(x => x.Key == "BannerGiayNu");
                                    var bannerDepNam = Model.FirstOrDefault(x => x.Key == "BannerDepNam");
                                }
                                
                                <!-- Ảnh Background Hero -->
                                <div class="col-lg-6">
                                    <div class="card border border-gray-2">
                                        <div class="card-body p-3">
                                            <label class="fw-semibold mb-1 d-block fs-12">1. Ảnh Background (Hero)</label>
                                            <p class="fs-11 text-muted mb-2">Kích thước: <strong>1920x600px</strong></p>
                                            <div class="mb-2">
                                                <div class="w-100" style="height: 50px; overflow: hidden; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <img src="@(heroBg?.Value ?? "/store/images/slide-01.jpg")" alt="Hero" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/store/images/slide-01.jpg'">
                                                </div>
                                            </div>
                                            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageType" value="HeroBackground" />
                                                <div class="input-group input-group-sm mb-2">
                                                    <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                                    <i class="feather-upload me-1"></i>
                                                    <span>Cập nhật</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Ảnh Giày Nam -->
                                <div class="col-lg-6">
                                    <div class="card border border-gray-2">
                                        <div class="card-body p-3">
                                            <label class="fw-semibold mb-1 d-block fs-12">2. Ảnh Giày Nam</label>
                                            <p class="fs-11 text-muted mb-2">Kích thước: <strong>600x400px</strong></p>
                                            <div class="mb-2">
                                                <div class="w-100" style="height: 50px; overflow: hidden; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <img src="@(bannerGiayNam?.Value ?? "/store/images/banner-01.jpg")" alt="Giày Nam" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/store/images/banner-01.jpg'">
                                                </div>
                                            </div>
                                            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageType" value="BannerGiayNam" />
                                                <div class="input-group input-group-sm mb-2">
                                                    <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                                    <i class="feather-upload me-1"></i>
                                                    <span>Cập nhật</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Ảnh Giày Nữ -->
                                <div class="col-lg-6">
                                    <div class="card border border-gray-2">
                                        <div class="card-body p-3">
                                            <label class="fw-semibold mb-1 d-block fs-12">3. Ảnh Giày Nữ</label>
                                            <p class="fs-11 text-muted mb-2">Kích thước: <strong>600x400px</strong></p>
                                            <div class="mb-2">
                                                <div class="w-100" style="height: 50px; overflow: hidden; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <img src="@(bannerGiayNu?.Value ?? "/store/images/banner-02.jpg")" alt="Giày Nữ" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/store/images/banner-02.jpg'">
                                                </div>
                                            </div>
                                            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageType" value="BannerGiayNu" />
                                                <div class="input-group input-group-sm mb-2">
                                                    <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                                    <i class="feather-upload me-1"></i>
                                                    <span>Cập nhật</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Ảnh Dép Nam -->
                                <div class="col-lg-6">
                                    <div class="card border border-gray-2">
                                        <div class="card-body p-3">
                                            <label class="fw-semibold mb-1 d-block fs-12">4. Ảnh Dép Nam</label>
                                            <p class="fs-11 text-muted mb-2">Kích thước: <strong>600x400px</strong></p>
                                            <div class="mb-2">
                                                <div class="w-100" style="height: 50px; overflow: hidden; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <img src="@(bannerDepNam?.Value ?? "/store/images/banner-03.jpg")" alt="Dép Nam" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/store/images/banner-03.jpg'">
                                                </div>
                                            </div>
                                            <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageType" value="BannerDepNam" />
                                                <div class="input-group input-group-sm mb-2">
                                                    <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                                    <i class="feather-upload me-1"></i>
                                                    <span>Cập nhật</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <hr class="my-4">
                        <!-- Tất cả Banner/Ảnh -->
                        <div>
                            <h5 class="fw-bold mb-4">
                                <span class="d-block mb-2">Tất cả Banner/Ảnh:</span>
                                <span class="fs-12 fw-normal text-muted text-truncate-1-line">Quản lý tất cả banner và ảnh đã tải lên</span>
                            </h5>
                            @if (ViewBag.AllImages != null && ((List<dynamic>)ViewBag.AllImages).Any())
                            {
                                <div class="row g-3">
                                    @foreach (var img in (List<dynamic>)ViewBag.AllImages)
                                    {
                                        <div class="col-lg-2 col-md-3 col-sm-4 col-6">
                                            <div class="card border border-gray-2 position-relative">
                                                <div class="position-relative" style="height: 120px; overflow: hidden;">
                                                    @if (img.IsVideo)
                                                    {
                                                        <video src="@img.Url" class="img-fluid w-100 h-100" style="object-fit: cover;" controls></video>
                                                    }
                                                    else
                                                    {
                                                        <img src="@img.Url" alt="@img.Name" class="img-fluid w-100 h-100" style="object-fit: cover;">
                                                    }
                                                    <div class="position-absolute top-0 end-0 p-2">
                                                        <form asp-action="DeleteImage" method="post" class="m-0">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="imagePath" value="@img.FullPath" />
                                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa ảnh này?');" data-bs-toggle="tooltip" title="Xóa">
                                                                <i class="feather-trash-2"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                                <div class="card-body p-2">
                                                    <p class="fs-12 text-muted mb-1 text-truncate" style="max-width: 100%;">@img.Name</p>
                                                    <p class="fs-11 text-muted mb-0">@img.Type</p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <p class="text-muted mb-0">Chưa có banner/ảnh nào.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
