@model IEnumerable<SiteSetting>
@{
    ViewData["Title"] = "Cài đặt web";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Cài đặt web</h4>
        <div>
            <button type="submit" form="settingsForm" class="btn btn-primary">
                <i class="feather-save me-2"></i>Lưu cài đặt
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">
                    <ul class="nav nav-tabs card-header-tabs" id="settingsTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#generalTab" type="button" role="tab">
                                Cài đặt cơ bản
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="images-tab" data-bs-toggle="tab" data-bs-target="#imagesTab" type="button" role="tab">
                                Hình ảnh & Banner
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    
                    <div class="tab-content" id="settingsTabContent">
                        <!-- Tab Cài đặt cơ bản -->
                        <div class="tab-pane fade show active" id="generalTab" role="tabpanel">
                            <form id="settingsForm" asp-action="Save" method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                
                                <div class="row">
                                    <div class="col-lg-8">
                                        <h5 class="fw-bold mb-4">Cài đặt website</h5>
                                        
                                        @foreach (var s in Model.Where(x => !x.Key.StartsWith("Banner") && !x.Key.StartsWith("Video")))
                                        {
                                            <div class="mb-3">
                                                <label class="form-label">@s.Key</label>
                                                <input type="text" name="values[@s.Key]" value="@s.Value" class="form-control" placeholder="@s.Key">
                                            </div>
                                        }
                                        
                                        <hr class="my-4">
                                        
                                        <h6 class="fw-bold mb-3">Thêm cài đặt mới</h6>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Key</label>
                                                <input type="text" name="newKey" class="form-control" placeholder="Key (VD: SiteName)">
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Value</label>
                                                <input type="text" name="newValue" class="form-control" placeholder="Value">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        
                        <!-- Tab Hình ảnh & Banner -->
                        <div class="tab-pane fade" id="imagesTab" role="tabpanel">
                            <!-- Upload Banner/Video chung -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header fw-semibold">
                                    Tải lên Banner/Video
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small mb-3">Hỗ trợ: JPG, PNG, GIF, MP4, WebM</p>
                                    <form asp-action="UploadBanner" method="post" enctype="multipart/form-data">
                                        @Html.AntiForgeryToken()
                                        <div class="row g-3">
                                            <div class="col-lg-4">
                                                <label class="form-label">File (Ảnh/GIF/Video)</label>
                                                <input type="file" name="bannerFile" accept="image/*,video/*,.gif" class="form-control" required>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="form-label">Loại banner</label>
                                                <select name="bannerType" class="form-select">
                                                    <option value="home">Trang chủ</option>
                                                    <option value="promotion">Khuyến mãi</option>
                                                    <option value="monthly">Theo tháng</option>
                                                </select>
                                            </div>
                                            <div class="col-lg-5">
                                                <label class="form-label">Link (tùy chọn)</label>
                                                <input type="text" name="bannerLink" placeholder="https://..." class="form-control">
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="feather-upload me-2"></i>Tải lên Banner
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            
                            <!-- 4 Ảnh Chính Trang Chủ -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header fw-semibold">
                                    4 Ảnh Chính Trang Chủ
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small mb-3">Quản lý các ảnh hiển thị trên trang chủ</p>
                                    <div class="row g-3">
                                        @{
                                            var heroBg = Model.FirstOrDefault(x => x.Key == "HeroBackground");
                                            var bannerGiayNam = Model.FirstOrDefault(x => x.Key == "BannerGiayNam");
                                            var bannerGiayNu = Model.FirstOrDefault(x => x.Key == "BannerGiayNu");
                                            var bannerDepNam = Model.FirstOrDefault(x => x.Key == "BannerDepNam");
                                        }
                                        
                                        <!-- Ảnh Background Hero -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">1. Ảnh Background (Hero)</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>1920x600px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(heroBg?.Value ?? "/hexashop/assets/images/left-banner-image.jpg")" alt="Hero" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/left-banner-image.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="HeroBackground" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Ảnh Giày Nam -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">2. Ảnh Giày Nam</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>600x400px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerGiayNam?.Value ?? "/hexashop/assets/images/baner-right-image-01.jpg")" alt="Giày Nam" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/baner-right-image-01.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerGiayNam" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Ảnh Giày Nữ -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">3. Ảnh Giày Nữ</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>600x400px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerGiayNu?.Value ?? "/hexashop/assets/images/baner-right-image-02.jpg")" alt="Giày Nữ" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/baner-right-image-02.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerGiayNu" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Ảnh Dép Nam -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">4. Ảnh Dép Nam</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>600x400px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerDepNam?.Value ?? "/hexashop/assets/images/baner-right-image-03.jpg")" alt="Dép Nam" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/baner-right-image-03.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerDepNam" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Banner các trang khác -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header fw-semibold">
                                    Banner Các Trang Khác
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small mb-3">Quản lý banner cho các trang Giới thiệu, Blog, Liên hệ, Sản phẩm</p>
                                    <div class="row g-3">
                                        @{
                                            var bannerGioiThieu = Model.FirstOrDefault(x => x.Key == "BannerGioiThieu");
                                            var bannerBlog = Model.FirstOrDefault(x => x.Key == "BannerBlog");
                                            var bannerLienHe = Model.FirstOrDefault(x => x.Key == "BannerLienHe");
                                            var bannerSanPham = Model.FirstOrDefault(x => x.Key == "BannerSanPham");
                                        }
                                        
                                        <!-- Banner Giới thiệu -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">Banner Trang Giới thiệu</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>1920x300px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerGioiThieu?.Value ?? "/hexashop/assets/images/about-us-page-heading.jpg")" alt="Giới thiệu" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/about-us-page-heading.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerGioiThieu" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Banner Blog -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">Banner Trang Blog</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>1920x300px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerBlog?.Value ?? "/hexashop/assets/images/about-us-page-heading.jpg")" alt="Blog" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/about-us-page-heading.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerBlog" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Banner Liên hệ -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">Banner Trang Liên hệ</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>1920x300px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerLienHe?.Value ?? "/hexashop/assets/images/about-us-page-heading.jpg")" alt="Liên hệ" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/about-us-page-heading.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerLienHe" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Banner Sản phẩm -->
                                        <div class="col-lg-6">
                                            <div class="card border">
                                                <div class="card-body">
                                                    <label class="form-label fw-semibold">Banner Trang Sản phẩm</label>
                                                    <p class="text-muted small mb-2">Kích thước: <strong>1920x300px</strong></p>
                                                    <div class="mb-3">
                                                        <div class="w-100" style="height: 80px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6;">
                                                            <img src="@(bannerSanPham?.Value ?? "/hexashop/assets/images/about-us-page-heading.jpg")" alt="Sản phẩm" class="img-fluid w-100 h-100" style="object-fit: cover;" onerror="this.src='/hexashop/assets/images/about-us-page-heading.jpg'">
                                                        </div>
                                                    </div>
                                                    <form asp-action="UploadHomeImage" method="post" enctype="multipart/form-data">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="imageType" value="BannerSanPham" />
                                                        <div class="mb-2">
                                                            <input type="file" name="imageFile" accept="image/*" class="form-control form-control-sm" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-sm btn-primary w-100">
                                                            <i class="feather-upload me-1"></i>Cập nhật
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Tất cả Banner/Ảnh -->
                            <div class="card shadow-sm">
                                <div class="card-header fw-semibold">
                                    Tất cả Banner/Ảnh
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small mb-3">Quản lý tất cả banner và ảnh đã tải lên</p>
                                    @if (ViewBag.AllImages != null && ((List<dynamic>)ViewBag.AllImages).Any())
                                    {
                                        <div class="row g-3">
                                            @foreach (var img in (List<dynamic>)ViewBag.AllImages)
                                            {
                                                <div class="col-lg-2 col-md-3 col-sm-4 col-6">
                                                    <div class="card border position-relative">
                                                        <div class="position-relative" style="height: 120px; overflow: hidden; border-radius: 8px;">
                                                            @if (img.IsVideo)
                                                            {
                                                                <video src="@img.Url" class="img-fluid w-100 h-100" style="object-fit: cover;" controls></video>
                                                            }
                                                            else
                                                            {
                                                                <img src="@img.Url" alt="@img.Name" class="img-fluid w-100 h-100" style="object-fit: cover;">
                                                            }
                                                            <div class="position-absolute top-0 end-0 p-2">
                                                                <form asp-action="DeleteImage" method="post" class="m-0">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="imagePath" value="@img.FullPath" />
                                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa ảnh này?');" title="Xóa">
                                                                        <i class="feather-trash-2"></i>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                        <div class="card-body p-2">
                                                            <p class="small text-muted mb-1 text-truncate">@img.Name</p>
                                                            <p class="small text-muted mb-0">@img.Type</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-5">
                                            <i class="feather-image fs-1 text-muted mb-3 d-block"></i>
                                            <p class="text-muted mb-0">Chưa có banner/ảnh nào.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize Bootstrap tabs
    var triggerTabList = [].slice.call(document.querySelectorAll('#settingsTabs button'));
    triggerTabList.forEach(function (triggerEl) {
        var tabTrigger = new bootstrap.Tab(triggerEl);
        triggerEl.addEventListener('click', function (event) {
            event.preventDefault();
            tabTrigger.show();
        });
    });
});
</script>
}
