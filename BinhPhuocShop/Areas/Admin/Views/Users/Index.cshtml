@model IEnumerable<User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var users = ViewBag.Users as IEnumerable<User> ?? Model;
    var total = ViewBag.Total as int? ?? 0;
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 20;
    var role = ViewBag.Role as string ?? "all";
    var search = ViewBag.Search as string ?? "";
}

@section PageHeaderRight {
    <div class="dropdown">
        <a class="btn btn-icon btn-light-brand" data-bs-toggle="dropdown" data-bs-offset="0, 10" data-bs-auto-close="outside">
            <i class="feather-filter"></i>
        </a>
        <div class="dropdown-menu dropdown-menu-end">
            <a href="@Url.Action("Index", new { role = "all", search = search })" class="dropdown-item @(role == "all" ? "active" : "")">
                <i class="feather-users me-3"></i>
                <span>Tất cả</span>
            </a>
            <a href="@Url.Action("Index", new { role = "Admin", search = search })" class="dropdown-item @(role == "Admin" ? "active" : "")">
                <i class="feather-shield me-3"></i>
                <span>Quản trị viên</span>
            </a>
            <a href="@Url.Action("Index", new { role = "Manager", search = search })" class="dropdown-item @(role == "Manager" ? "active" : "")">
                <i class="feather-user-check me-3"></i>
                <span>Quản lý</span>
            </a>
            <a href="@Url.Action("Index", new { role = "Customer", search = search })" class="dropdown-item @(role == "Customer" ? "active" : "")">
                <i class="feather-user me-3"></i>
                <span>Khách hàng</span>
            </a>
        </div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="feather-plus me-2"></i>
        <span>Thêm người dùng</span>
    </a>
}

<div class="row mb-3">
    <div class="col-lg-12">
        <form method="get" class="d-flex gap-2">
            <input type="hidden" name="role" value="@role" />
            <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="Tìm kiếm theo tên hoặc email..." style="max-width: 300px;">
            <button type="submit" class="btn btn-sm btn-light-brand">
                <i class="feather-search me-2"></i>
                <span>Tìm kiếm</span>
            </button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a href="@Url.Action("Index", new { role = role })" class="btn btn-sm btn-light">
                    <i class="feather-x"></i>
                </a>
            }
        </form>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card stretch stretch-full">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="wd-30">
                                    <div class="custom-control custom-checkbox ms-1">
                                        <input type="checkbox" class="custom-control-input" id="checkAll">
                                        <label class="custom-control-label" for="checkAll"></label>
                                    </div>
                                </th>
                                <th>ID</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Điện thoại</th>
                                <th>Vai trò</th>
                                <th>Ngày tạo</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (users.Any())
                            {
                                @foreach (var u in users)
                                {
                                    <tr class="single-item">
                                        <td>
                                            <div class="custom-control custom-checkbox ms-1">
                                                <input type="checkbox" class="custom-control-input checkbox" id="checkBox_@u.Id">
                                                <label class="custom-control-label" for="checkBox_@u.Id"></label>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-soft-primary text-primary">@u.Id</span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold d-block" style="max-width: 150px;">@u.Name</span>
                                        </td>
                                        <td>
                                            <span class="text-muted fs-12 text-truncate d-block" style="max-width: 200px;">@u.Email</span>
                                        </td>
                                        <td>
                                            <span class="text-muted fs-12">@(u.Phone ?? "—")</span>
                                        </td>
                                        <td>
                                            @switch (u.Role)
                                            {
                                                case "Admin":
                                                    <span class="badge bg-soft-danger text-danger">Quản trị viên</span>
                                                    break;
                                                case "Manager":
                                                    <span class="badge bg-soft-warning text-warning">Quản lý</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-soft-info text-info">Khách hàng</span>
                                                    break;
                                            }
                                        </td>
                                        <td>
                                            <span class="text-muted fs-12">@u.CreatedAt.ToString("dd/MM/yyyy")</span>
                                        </td>
                                        <td>
                                            @if (u.IsActive)
                                            {
                                                <span class="badge bg-soft-success text-success">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-soft-secondary text-secondary">Khóa</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="hstack gap-2 justify-content-end">
                                                <a asp-action="Edit" asp-route-id="@u.Id" class="avatar-text avatar-sm" data-bs-toggle="tooltip" title="Sửa">
                                                    <i class="feather-edit-3"></i>
                                                </a>
                                                <div class="dropdown">
                                                    <a href="javascript:void(0)" class="avatar-text avatar-sm" data-bs-toggle="dropdown" data-bs-offset="0,21">
                                                        <i class="feather-more-horizontal"></i>
                                                    </a>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@u.Id">
                                                                <i class="feather-edit-3 me-3"></i>
                                                                <span>Sửa</span>
                                                            </a>
                                                        </li>
                                                        <li class="dropdown-divider"></li>
                                                        <li>
                                                            <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="m-0">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Xóa người dùng này?');">
                                                                    <i class="feather-trash-2 me-3"></i>
                                                                    <span>Xóa</span>
                                                                </button>
                                                            </form>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-5">
                                        <p class="text-muted mb-0">Chưa có người dùng nào.</p>
                                        <a asp-action="Create" class="btn btn-sm btn-primary mt-2">
                                            <i class="feather-plus me-2"></i>Thêm người dùng đầu tiên
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (total > pageSize)
{
    <div class="row mt-3">
        <div class="col-lg-12">
            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= (total + pageSize - 1) / pageSize; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { role = role, search = search, page = i, pageSize = pageSize })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
}
