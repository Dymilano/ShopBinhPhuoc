@model User
@{
    ViewData["Title"] = ViewBag.IsCreateAdmin == true ? "Cấp tài khoản Admin" : "Thêm người dùng";
    var isAdmin = Model?.Role == "Admin";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">@ViewData["Title"]</h4>
        <div>
            <a asp-action="Index" class="btn btn-light me-2">
                <i class="feather-arrow-left me-2"></i>Quay lại
            </a>
            <button type="submit" form="userForm" class="btn @(isAdmin ? "btn-danger" : "btn-primary")">
                <i class="feather-save me-2"></i>@(isAdmin ? "Cấp tài khoản Admin" : "Lưu người dùng")
            </button>
        </div>
    </div>

    <form id="userForm" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger"></div>
        
        <div class="row">
            <!-- CỘT TRÁI -->
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Thông tin người dùng
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                            <input asp-for="Name" type="text" class="form-control" placeholder="Họ tên" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" required>
                            <small class="text-muted">Email sẽ được dùng để đăng nhập</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                            <input name="password" type="password" class="form-control" placeholder="Mật khẩu (tối thiểu 6 ký tự)" required minlength="6">
                            <small class="text-muted">Mật khẩu phải có ít nhất 6 ký tự</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" type="tel" class="form-control" placeholder="Số điện thoại (10-11 chữ số)" pattern="[0-9]{10,11}" required>
                            <small class="text-muted">Ví dụ: 0912345678</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Địa chỉ <span class="text-danger">*</span></label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Địa chỉ" required></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI -->
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Phân quyền
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Vai trò <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select" required>
                                <option value="Customer" selected="@(Model?.Role == "Customer")">Khách hàng</option>
                                <option value="Manager" selected="@(Model?.Role == "Manager")">Quản lý</option>
                                <option value="Admin" selected="@(Model?.Role == "Admin")">Quản trị viên (Admin)</option>
                            </select>
                            @if (isAdmin)
                            {
                                <div class="alert alert-warning mt-2 mb-0 small">
                                    <i class="feather-alert-triangle me-1"></i>
                                    Tài khoản Admin có quyền truy cập đầy đủ vào khu vực quản trị.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mt-3">
                    <div class="card-header fw-semibold">
                        Trạng thái
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                            <label class="form-check-label" asp-for="IsActive">Hoạt động</label>
                        </div>
                        <small class="text-muted">Tài khoản sẽ được kích hoạt ngay sau khi tạo</small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
