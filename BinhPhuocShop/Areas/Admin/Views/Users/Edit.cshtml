@model User
@{
    ViewData["Title"] = "Sửa người dùng";
    var totalOrders = ViewBag.TotalOrders as int? ?? 0;
    var totalSpent = ViewBag.TotalSpent as decimal? ?? 0;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Sửa người dùng</h4>
        <div>
            <a asp-action="Index" class="btn btn-light me-2">
                <i class="feather-arrow-left me-2"></i>Quay lại
            </a>
            <button type="submit" form="userForm" class="btn btn-primary">
                <i class="feather-save me-2"></i>Cập nhật người dùng
            </button>
        </div>
    </div>

    <form id="userForm" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="alert alert-danger"></div>
        
        <div class="row">
            <!-- CỘT TRÁI -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        Thông tin người dùng
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Họ tên <span class="text-danger">*</span></label>
                            <input asp-for="Name" type="text" class="form-control" placeholder="Họ tên" required value="@Model.Name">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" required value="@Model.Email">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input name="newPassword" type="password" class="form-control" placeholder="Để trống giữ nguyên mật khẩu cũ">
                            <small class="text-muted">Để trống nếu không muốn đổi mật khẩu. Mật khẩu mới phải có ít nhất 6 ký tự.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" type="tel" class="form-control" placeholder="Số điện thoại (10-11 chữ số)" pattern="[0-9]{10,11}" required value="@Model.Phone">
                            <small class="text-muted">Ví dụ: 0912345678</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Địa chỉ <span class="text-danger">*</span></label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Địa chỉ" required>@Model.Address</textarea>
                        </div>
                    </div>
                </div>

                @if (totalOrders > 0)
                {
                    <div class="card shadow-sm">
                        <div class="card-header fw-semibold">
                            Thống kê đơn hàng
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="text-center p-3 border rounded">
                                        <div class="fs-3 fw-bold text-primary">@totalOrders</div>
                                        <div class="text-muted small">Tổng đơn hàng</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-center p-3 border rounded">
                                        <div class="fs-3 fw-bold text-success">@totalSpent.ToString("N0")₫</div>
                                        <div class="text-muted small">Tổng chi tiêu</div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3">
                                <a href="@Url.Action("Index", "Orders", new { area = "Admin", userId = Model.Id })" class="btn btn-sm btn-outline-primary w-100">
                                    <i class="feather-shopping-cart me-2"></i>Xem đơn hàng của người dùng này
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- CỘT PHẢI -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        Phân quyền
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Vai trò <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select" required>
                                <option value="Customer" selected="@(Model.Role == "Customer")">Khách hàng</option>
                                <option value="Manager" selected="@(Model.Role == "Manager")">Quản lý</option>
                                <option value="Admin" selected="@(Model.Role == "Admin")">Quản trị viên (Admin)</option>
                            </select>
                            @if (Model.Role == "Admin")
                            {
                                <div class="alert alert-danger mt-2 mb-0 small">
                                    <i class="feather-alert-triangle me-1"></i>
                                    Tài khoản Admin có quyền truy cập đầy đủ vào khu vực quản trị.
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Trạng thái
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked="@Model.IsActive">
                            <label class="form-check-label" asp-for="IsActive">Hoạt động</label>
                        </div>
                        <small class="text-muted">Tài khoản khóa sẽ không thể đăng nhập</small>
                    </div>
                </div>

                <div class="card shadow-sm mt-3">
                    <div class="card-header fw-semibold">
                        Thông tin tài khoản
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <small class="text-muted">Ngày tạo</small>
                            <div class="fw-semibold">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div>
                                <small class="text-muted">Cập nhật lần cuối</small>
                                <div class="fw-semibold">@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
