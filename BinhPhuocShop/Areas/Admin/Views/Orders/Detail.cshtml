@model BinhPhuocShop.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng " + Model.OrderCode;
}

@section PageHeaderRight {
    <a asp-action="Index" class="btn btn-light-brand">
        <i class="feather-arrow-left me-2"></i>
        <span>Quay lại</span>
    </a>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card border-top-0 mb-4">
            <div class="card-header border-bottom">
                <h5 class="mb-0">
                    <i class="feather-user me-2"></i>
                    Thông tin khách hàng
                </h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-lg-3">
                        <label class="fw-semibold text-muted">Họ tên:</label>
                    </div>
                    <div class="col-lg-9">
                        <p class="mb-0 fw-semibold">@Model.CustomerName</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-lg-3">
                        <label class="fw-semibold text-muted">Số điện thoại:</label>
                    </div>
                    <div class="col-lg-9">
                        <p class="mb-0">
                            <a href="tel:@Model.Phone">@Model.Phone</a>
                        </p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-lg-3">
                        <label class="fw-semibold text-muted">Email:</label>
                    </div>
                    <div class="col-lg-9">
                        <p class="mb-0">
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-lg-3">
                        <label class="fw-semibold text-muted">Địa chỉ:</label>
                    </div>
                    <div class="col-lg-9">
                        <p class="mb-0">@Model.Address</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="row">
                        <div class="col-lg-3">
                            <label class="fw-semibold text-muted">Ghi chú:</label>
                        </div>
                        <div class="col-lg-9">
                            <div class="p-3 border border-gray-2 rounded bg-gray-1">
                                <p class="mb-0" style="white-space: pre-wrap;">@Model.Note</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="card border-top-0">
            <div class="card-header border-bottom">
                <h5 class="mb-0">
                    <i class="feather-shopping-bag me-2"></i>
                    Sản phẩm
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Size</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@item.ProductId" class="fw-semibold">
                                            @item.ProductName
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge bg-light-brand">@(item.Size ?? "-")</span>
                                    </td>
                                    <td class="text-end">@item.Price.ToString("N0")₫</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end fw-semibold">@item.Amount.ToString("N0")₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-end">
                                    <span class="text-danger fs-5 fw-bold">@Model.TotalAmount.ToString("N0")₫</span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-top-0">
            <div class="card-header border-bottom">
                <h5 class="mb-0">
                    <i class="feather-settings me-2"></i>
                    Cập nhật trạng thái
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <label class="fw-semibold text-muted mb-2 d-block">Mã đơn hàng:</label>
                    <p class="mb-0 fw-bold">@Model.OrderCode</p>
                </div>
                <div class="mb-4">
                    <label class="fw-semibold text-muted mb-2 d-block">Ngày đặt:</label>
                    <p class="mb-0">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="mb-4">
                    <label class="fw-semibold text-muted mb-2 d-block">Trạng thái hiện tại:</label>
                    @switch (Model.Status)
                    {
                        case "pending":
                            <span class="badge bg-warning">Chờ xử lý</span>
                            break;
                        case "confirmed":
                            <span class="badge bg-info">Đã xác nhận</span>
                            break;
                        case "shipping":
                            <span class="badge bg-primary">Đang giao</span>
                            break;
                        case "completed":
                            <span class="badge bg-success">Hoàn thành</span>
                            break;
                        case "cancelled":
                            <span class="badge bg-danger">Đã hủy</span>
                            break;
                        default:
                            <span class="badge bg-secondary">@Model.Status</span>
                            break;
                    }
                </div>
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Cập nhật trạng thái:</label>
                        <select name="status" class="form-select">
                            <option value="pending" selected="@(Model.Status == "pending")">Chờ xử lý</option>
                            <option value="confirmed" selected="@(Model.Status == "confirmed")">Đã xác nhận</option>
                            <option value="shipping" selected="@(Model.Status == "shipping")">Đang giao</option>
                            <option value="completed" selected="@(Model.Status == "completed")">Hoàn thành</option>
                            <option value="cancelled" selected="@(Model.Status == "cancelled")">Đã hủy</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="feather-save me-2"></i>
                        <span>Cập nhật trạng thái</span>
                    </button>
                </form>
            </div>
            <div class="card-footer border-top">
                <a asp-action="Index" class="btn btn-light-brand w-100">
                    <i class="feather-arrow-left me-2"></i>
                    <span>Quay lại danh sách</span>
                </a>
            </div>
        </div>
    </div>
</div>
