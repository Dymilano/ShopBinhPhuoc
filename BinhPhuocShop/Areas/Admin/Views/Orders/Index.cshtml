@{
    ViewData["Title"] = "Đơn hàng";
    var orders = ViewBag.Orders as IEnumerable<BinhPhuocShop.Models.Order> ?? new List<BinhPhuocShop.Models.Order>();
    var total = (int)(ViewBag.Total ?? 0);
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var status = ViewBag.Status as string;
}

@section PageHeaderRight {
    <div class="dropdown">
        <a class="btn btn-icon btn-light-brand" data-bs-toggle="dropdown" data-bs-offset="0, 10" data-bs-auto-close="outside">
            <i class="feather-filter"></i>
        </a>
        <div class="dropdown-menu dropdown-menu-end">
            <form method="get" class="p-3">
                <select name="status" class="form-control form-control-sm mb-2" onchange="this.form.submit()">
                    <option value="">Tất cả trạng thái</option>
                    @if (status == "pending")
                    {
                        <option value="pending" selected>Chờ xử lý</option>
                    }
                    else
                    {
                        <option value="pending">Chờ xử lý</option>
                    }
                    @if (status == "confirmed")
                    {
                        <option value="confirmed" selected>Đã xác nhận</option>
                    }
                    else
                    {
                        <option value="confirmed">Đã xác nhận</option>
                    }
                    @if (status == "shipping")
                    {
                        <option value="shipping" selected>Đang giao</option>
                    }
                    else
                    {
                        <option value="shipping">Đang giao</option>
                    }
                    @if (status == "completed")
                    {
                        <option value="completed" selected>Hoàn thành</option>
                    }
                    else
                    {
                        <option value="completed">Hoàn thành</option>
                    }
                    @if (status == "cancelled")
                    {
                        <option value="cancelled" selected>Đã hủy</option>
                    }
                    else
                    {
                        <option value="cancelled">Đã hủy</option>
                    }
                </select>
            </form>
        </div>
    </div>
}

<div class="row">
    <div class="col-lg-12">
        <div class="card stretch stretch-full">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="wd-30">
                                    <div class="custom-control custom-checkbox ms-1">
                                        <input type="checkbox" class="custom-control-input" id="checkAll">
                                        <label class="custom-control-label" for="checkAll"></label>
                                    </div>
                                </th>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Số điện thoại</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Ngày đặt</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (orders.Any())
                            {
                                @foreach (var o in orders)
                                {
                                    <tr class="single-item">
                                        <td>
                                            <div class="custom-control custom-checkbox ms-1">
                                                <input type="checkbox" class="custom-control-input checkbox" id="checkBox_@o.Id">
                                                <label class="custom-control-label" for="checkBox_@o.Id"></label>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="fw-semibold">@o.OrderCode</span>
                                        </td>
                                        <td>
                                            <span>@o.CustomerName</span>
                                        </td>
                                        <td>
                                            <a href="tel:@o.Phone">@o.Phone</a>
                                        </td>
                                        <td>
                                            <span class="fw-bold">@o.TotalAmount.ToString("N0")₫</span>
                                        </td>
                                        <td>
                                            @{
                                                var statusClass = o.Status switch
                                                {
                                                    "completed" => "bg-soft-success text-success",
                                                    "cancelled" => "bg-soft-danger text-danger",
                                                    "pending" => "bg-soft-warning text-warning",
                                                    "confirmed" => "bg-soft-info text-info",
                                                    "shipping" => "bg-soft-primary text-primary",
                                                    _ => "bg-soft-secondary text-secondary"
                                                };
                                                var statusText = o.Status switch
                                                {
                                                    "pending" => "Chờ xử lý",
                                                    "confirmed" => "Đã xác nhận",
                                                    "shipping" => "Đang giao",
                                                    "completed" => "Hoàn thành",
                                                    "cancelled" => "Đã hủy",
                                                    _ => o.Status
                                                };
                                            }
                                            <span class="badge @statusClass">@statusText</span>
                                        </td>
                                        <td>
                                            <span class="text-muted">@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                        </td>
                                        <td>
                                            <div class="hstack gap-2 justify-content-end">
                                                <a asp-action="Detail" asp-route-id="@o.Id" class="avatar-text avatar-md" data-bs-toggle="tooltip" title="Xem chi tiết">
                                                    <i class="feather-eye"></i>
                                                </a>
                                                <div class="dropdown">
                                                    <a href="javascript:void(0)" class="avatar-text avatar-md" data-bs-toggle="dropdown" data-bs-offset="0,21">
                                                        <i class="feather-more-horizontal"></i>
                                                    </a>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item" asp-action="Detail" asp-route-id="@o.Id">
                                                                <i class="feather-eye me-3"></i>
                                                                <span>Xem chi tiết</span>
                                                            </a>
                                                        </li>
                                                        <li class="dropdown-divider"></li>
                                                        <li>
                                                            <a class="dropdown-item" href="javascript:void(0)">
                                                                <i class="feather-printer me-3"></i>
                                                                <span>In đơn hàng</span>
                                                            </a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-5">
                                        <p class="text-muted mb-0">Chưa có đơn hàng nào.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            @if (totalPages > 1)
            {
                <div class="card-footer border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center mb-0">
                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == page ? "active" : "")">
                                    <a class="page-link" href="?page=@i&status=@status">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>
