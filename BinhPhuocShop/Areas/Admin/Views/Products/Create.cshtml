@model Product
@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Thêm sản phẩm</h4>
        <div>
            <a asp-action="Index" class="btn btn-light me-2">
                <i class="feather-arrow-left me-2"></i>Quay lại
            </a>
            <button type="submit" form="productForm" class="btn btn-primary">
                <i class="feather-save me-2"></i>Lưu sản phẩm
            </button>
        </div>
    </div>

    <form id="productForm" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger"></div>
        
        <div class="row">
            <!-- CỘT TRÁI -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        Thông tin sản phẩm
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input asp-for="Name" type="text" class="form-control" placeholder="Tên sản phẩm">
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label">Slug</label>
                            <input asp-for="Slug" type="text" class="form-control" placeholder="Để trống sẽ tự động tạo">
                            <small class="text-muted">Để trống sẽ tự động tạo</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShortDescription" class="form-label">Mô tả ngắn</label>
                            <textarea asp-for="ShortDescription" class="form-control" rows="3" placeholder="Mô tả ngắn về sản phẩm"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả chi tiết</label>
                            <textarea id="Description" name="Description" class="form-control" rows="6" placeholder="Mô tả chi tiết sản phẩm">@Model.Description</textarea>
                            <div class="mt-2 p-2 border rounded bg-light">
                                <label class="fs-11 fw-semibold mb-1 d-block">Chèn ảnh vào mô tả:</label>
                                <div class="input-group input-group-sm">
                                    <input type="file" id="descImageFile" accept="image/*" class="form-control">
                                    <button type="button" class="btn btn-sm btn-primary" id="btnUploadDescImage">Tải lên và chèn</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        Hình ảnh sản phẩm
                    </div>
                    <div class="card-body">
                        <p class="fs-12 text-muted mb-3">Tối đa 5 ảnh (ảnh 1 = ảnh chính). Kích thước khuyến nghị: 600x400px</p>
                        <div class="row g-3">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <div class="col-lg-4 col-md-6">
                                    <label class="form-label">Ảnh @i @(i == 1 ? "(chính)" : "")</label>
                                    <input type="file" name="@(i == 1 ? "imageFile" : "imageFile" + i)" accept="image/*" class="form-control form-control-sm">
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Giá & Tồn kho
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label">Giá <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input asp-for="Price" type="number" step="1000" class="form-control" placeholder="Giá sản phẩm">
                                    <span class="input-group-text">₫</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SalePrice" class="form-label">Giá khuyến mãi</label>
                                <div class="input-group">
                                    <input asp-for="SalePrice" type="number" step="1000" class="form-control" placeholder="Giá khuyến mãi">
                                    <span class="input-group-text">₫</span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label asp-for="Sku" class="form-label">Mã SKU</label>
                                <input asp-for="Sku" type="text" class="form-control" placeholder="Mã SKU">
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label">Tồn kho</label>
                                <input asp-for="Stock" type="number" class="form-control" placeholder="Số lượng" value="0">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        Phân loại
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                <option value="">Chọn danh mục (không bắt buộc)</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BrandId" class="form-label">Thương hiệu</label>
                            <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select">
                                <option value="">Chọn thương hiệu</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Trạng thái
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" value="0">
                        </div>

                        <div class="form-check form-switch mb-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                            <label class="form-check-label" asp-for="IsActive">Hiển thị</label>
                        </div>

                        <div class="form-check form-switch">
                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox">
                            <label class="form-check-label" asp-for="IsFeatured">Nổi bật</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function() {
  var descTa = document.getElementById('Description');
  var descInput = document.getElementById('descImageFile');
  var btnUpload = document.getElementById('btnUploadDescImage');
  if (btnUpload && descInput && descTa) {
    btnUpload.addEventListener('click', function() {
      if (!descInput.files || !descInput.files[0]) { alert('Chọn ảnh trước.'); return; }
      var fd = new FormData();
      fd.append('file', descInput.files[0]);
      fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
      btnUpload.disabled = true;
      fetch('/Admin/Upload/ContentImage', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          btnUpload.disabled = false;
          if (data.ok && data.url) {
            var img = '<img src="' + data.url + '" alt="" style="max-width:100%; height:auto;" />';
            var start = descTa.selectionStart, end = descTa.selectionEnd;
            var text = descTa.value;
            descTa.value = text.slice(0, start) + img + text.slice(end);
            descTa.focus();
            descInput.value = '';
          } else { alert(data.msg || 'Lỗi tải ảnh'); }
        })
        .catch(function() { btnUpload.disabled = false; alert('Lỗi tải ảnh'); });
    });
  }
})();
</script>
}
