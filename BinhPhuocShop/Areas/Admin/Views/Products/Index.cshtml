@model IEnumerable<Product>
@{
    ViewData["Title"] = "Sản phẩm";
}
<div class="flex flex-row justify-between items-center mb-6">
    <h5 class="text-gray-800 font-semibold m-0">Danh sách sản phẩm</h5>
    <a asp-action="Create" class="capitalize font-medium text-sm bg-teal-600 text-white px-4 py-2 rounded hover:bg-teal-700 transition duration-200">Thêm sản phẩm</a>
</div>
<div class="card">
    <div class="card-body p-0 overflow-x-auto">
        @if (Model.Any())
        {
        <table class="table-auto w-full text-left">
            <thead>
                <tr>
                    <th class="px-4 py-3 border-b border-gray-200 bg-gray-50 text-gray-700 font-semibold text-sm">Ảnh</th>
                    <th class="px-4 py-3 border-b border-gray-200 bg-gray-50 text-gray-700 font-semibold text-sm">Tên</th>
                    <th class="px-4 py-3 border-b border-gray-200 bg-gray-50 text-gray-700 font-semibold text-sm">Danh mục</th>
                    <th class="px-4 py-3 border-b border-gray-200 bg-gray-50 text-gray-700 font-semibold text-sm">Giá</th>
                    <th class="px-4 py-3 border-b border-gray-200 bg-gray-50 text-gray-700 font-semibold text-sm">Trạng thái</th>
                    <th class="px-4 py-3 border-b border-gray-200 bg-gray-50 text-gray-700 font-semibold text-sm"></th>
                </tr>
            </thead>
            <tbody class="text-gray-600">
                @foreach (var p in Model)
                {
                    <tr class="border-b border-gray-100 hover:bg-gray-50 transition duration-150">
                        <td class="px-4 py-3">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="" class="w-10 h-10 object-cover rounded flex-shrink-0" />
                            }
                            else
                            {
                                <span class="text-gray-400">—</span>
                            }
                        </td>
                        <td class="px-4 py-3 font-medium text-gray-800">@p.Name</td>
                        <td class="px-4 py-3">@p.Category?.Name</td>
                        <td class="px-4 py-3">@(p.SalePrice.HasValue ? p.SalePrice.Value.ToString("N0") + "₫" : p.Price.ToString("N0") + "₫")</td>
                        <td class="px-4 py-3">
                            @if (p.IsActive)
                            {<span class="text-xs px-2 py-1 rounded bg-green-100 text-green-800">Hiển thị</span>}
                            else
                            {<span class="text-xs px-2 py-1 rounded bg-gray-200 text-gray-600">Ẩn</span>}
                        </td>
                        <td class="px-4 py-3">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="text-teal-600 hover:text-teal-700 text-sm font-medium mr-2">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="inline" onsubmit="return confirm('Xóa sản phẩm này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-red-600 hover:text-red-700 text-sm font-medium bg-transparent border-0 cursor-pointer">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        }
        else
        {
            <p class="text-gray-500 text-center py-12">Chưa có sản phẩm nào.</p>
        }
    </div>
</div>
