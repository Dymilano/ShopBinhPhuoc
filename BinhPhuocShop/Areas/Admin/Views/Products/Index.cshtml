@model IEnumerable<Product>
@{
    ViewData["Title"] = "Sản phẩm";
}

@section PageHeaderRight {
    <div class="dropdown">
        <a class="btn btn-icon btn-light-brand" data-bs-toggle="dropdown" data-bs-offset="0, 10" data-bs-auto-close="outside">
            <i class="feather-filter"></i>
        </a>
        <div class="dropdown-menu dropdown-menu-end">
            <a href="@Url.Action("Index", new { status = "all" })" class="dropdown-item">
                <i class="feather-eye me-3"></i>
                <span>Tất cả</span>
            </a>
            <a href="@Url.Action("Index", new { status = "active" })" class="dropdown-item">
                <i class="feather-check-circle me-3"></i>
                <span>Đang hiển thị</span>
            </a>
            <a href="@Url.Action("Index", new { status = "inactive" })" class="dropdown-item">
                <i class="feather-x-circle me-3"></i>
                <span>Đã ẩn</span>
            </a>
        </div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="feather-plus me-2"></i>
        <span>Thêm sản phẩm</span>
    </a>
}

@{
    var categories = ViewBag.Categories as IEnumerable<BinhPhuocShop.Models.Category> ?? new List<BinhPhuocShop.Models.Category>();
}

@Html.AntiForgeryToken()

<div class="row">
    <div class="col-lg-12">
        <!-- Toolbar xóa hàng loạt -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="d-flex align-items-center gap-2 flex-nowrap">
                    <button type="button" id="btnDeleteSelected" class="btn btn-sm btn-danger" style="display: none; white-space: nowrap;">
                        <i class="bi bi-trash me-1"></i>
                        <span>Xóa đã chọn (<span id="selectedCount">0</span>)</span>
                    </button>
                    
                    <div class="dropdown">
                        <button class="btn btn-sm btn-warning dropdown-toggle" type="button" data-bs-toggle="dropdown" style="white-space: nowrap;">
                            <i class="bi bi-folder-x me-1"></i>
                            Xóa theo danh mục
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var cat in categories)
                            {
                                var categoryName = cat.Name;
                                <li>
                                    <form asp-action="DeleteByCategory" method="post" class="d-inline delete-category-form" data-category-name="@categoryName">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="categoryId" value="@cat.Id" />
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-folder me-2"></i>@cat.Name
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                    
                    <form asp-action="DeleteAll" method="post" class="d-inline flex-shrink-0" onsubmit="return confirm('CẢNH BÁO: Bạn có chắc muốn xóa TẤT CẢ sản phẩm? Hành động này không thể hoàn tác!');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger" style="white-space: nowrap;">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Xóa tất cả
                        </button>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="card stretch stretch-full">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover" id="productList">
                        <thead>
                            <tr>
                                <th class="wd-30">
                                    <div class="btn-group mb-1">
                                        <div class="custom-control custom-checkbox ms-1">
                                            <input type="checkbox" class="custom-control-input" id="checkAllProduct">
                                            <label class="custom-control-label" for="checkAllProduct"></label>
                                        </div>
                                    </div>
                                </th>
                                <th>Sản phẩm</th>
                                <th>Danh mục</th>
                                <th>Giá</th>
                                <th>Giá khuyến mãi</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var product in Model)
                                {
                                    <tr class="single-item">
                                        <td>
                                            <div class="item-checkbox ms-1">
                                                <div class="custom-control custom-checkbox">
                                                    <input type="checkbox" class="custom-control-input checkbox" id="checkBox_@product.Id" value="@product.Id" data-product-id="@product.Id">
                                                    <label class="custom-control-label" for="checkBox_@product.Id"></label>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Edit", new { id = product.Id })" class="hstack gap-2 align-items-center">
                                                <div class="avatar-image" style="width: 40px; height: 40px; overflow: hidden; border-radius: 4px; flex-shrink: 0; border: 1px solid #e5e5e5;">
                                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                                    {
                                                        <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid w-100 h-100" style="object-fit: cover;" />
                                                    }
                                                    else
                                                    {
                                                        <div class="w-100 h-100 bg-gray-200 d-flex align-items-center justify-content-center">
                                                            <i class="feather-image" style="font-size: 14px;"></i>
                                                        </div>
                                                    }
                                                </div>
                                                <div style="min-width: 0;">
                                                    <span class="d-block fw-semibold text-dark text-truncate mb-0" style="max-width: 200px; font-size: 13px;">@product.Name</span>
                                                    <span class="fs-11 d-block fw-normal text-muted text-truncate" style="max-width: 200px;">@product.Slug</span>
                                                </div>
                                            </a>
                                        </td>
                                        <td>
                                            <span class="badge bg-soft-primary text-primary">@(product.Category?.Name ?? "N/A")</span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold text-dark">@product.Price.ToString("N0")₫</span>
                                        </td>
                                        <td>
                                            @if (product.SalePrice.HasValue)
                                            {
                                                <span class="fw-semibold text-success">@product.SalePrice.Value.ToString("N0")₫</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (product.IsActive)
                                            {
                                                <span class="badge bg-soft-success text-success">Hiển thị</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-soft-secondary text-secondary">Ẩn</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Edit", new { id = product.Id })" class="btn btn-sm btn-outline-primary" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a href="@Url.Action("Detail", "Products", new { area = "", id = product.Id })" target="_blank" class="btn btn-sm btn-outline-info" title="Xem trên trang web">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@product.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Xóa">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <i class="feather-package fs-1 text-muted mb-3 d-block"></i>
                                        <p class="text-muted mb-3">Chưa có sản phẩm nào</p>
                                        <a href="@Url.Action("Create")" class="btn btn-primary">
                                            <i class="feather-plus me-2"></i>
                                            <span>Thêm sản phẩm đầu tiên</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Check all functionality
        const checkAll = document.getElementById('checkAllProduct');
        const checkboxes = document.querySelectorAll('#productList tbody .checkbox');
        const btnDeleteSelected = document.getElementById('btnDeleteSelected');
        const selectedCountSpan = document.getElementById('selectedCount');

        function updateDeleteButton() {
            const selected = Array.from(checkboxes).filter(cb => cb.checked);
            const count = selected.length;
            
            if (count > 0) {
                btnDeleteSelected.style.display = 'inline-block';
                selectedCountSpan.textContent = count;
            } else {
                btnDeleteSelected.style.display = 'none';
                selectedCountSpan.textContent = '0';
            }
            
            // Update check all checkbox
            if (checkAll) {
                checkAll.checked = count === checkboxes.length && count > 0;
                checkAll.indeterminate = count > 0 && count < checkboxes.length;
            }
        }

        checkAll?.addEventListener('change', function() {
            checkboxes.forEach(cb => cb.checked = this.checked);
            updateDeleteButton();
        });

        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateDeleteButton);
        });

        // Xóa đã chọn
        btnDeleteSelected?.addEventListener('click', function() {
            const selected = Array.from(checkboxes)
                .filter(cb => cb.checked)
                .map(cb => cb.value);
            
            if (selected.length === 0) {
                alert('Vui lòng chọn ít nhất một sản phẩm để xóa.');
                return;
            }
            
            if (!confirm(`Bạn có chắc muốn xóa ${selected.length} sản phẩm đã chọn? Hành động này không thể hoàn tác!`)) {
                return;
            }
            
            // Tạo form và submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("DeleteSelected")';
            
            // Anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token.value;
                form.appendChild(tokenInput);
            }
            
            // Thêm các ID đã chọn
            selected.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedIds';
                input.value = id;
                form.appendChild(input);
            });
            
            document.body.appendChild(form);
            form.submit();
        });

        function viewProduct(id) {
            window.location.href = '@Url.Action("Edit")?id=' + id;
        }

        // Xóa theo danh mục - xử lý confirm với tên danh mục
        document.querySelectorAll('.delete-category-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                const categoryName = this.getAttribute('data-category-name');
                if (!confirm(`Bạn có chắc muốn xóa TẤT CẢ sản phẩm trong danh mục "${categoryName}"? Hành động này không thể hoàn tác!`)) {
                    e.preventDefault();
                }
            });
        });

        // Initialize
        updateDeleteButton();
    </script>
}
