@model IEnumerable<Brand>
@{
    ViewData["Title"] = "Thương hiệu";
}

@section PageHeaderRight {
    <a asp-action="Create" class="btn btn-primary">
        <i class="feather-plus me-2"></i>
        <span>Thêm thương hiệu</span>
    </a>
}

<div class="row">
    <div class="col-lg-12">
        <div class="card stretch stretch-full">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="wd-30">
                                    <div class="custom-control custom-checkbox ms-1">
                                        <input type="checkbox" class="custom-control-input" id="checkAll">
                                        <label class="custom-control-label" for="checkAll"></label>
                                    </div>
                                </th>
                                <th>Logo</th>
                                <th>Tên</th>
                                <th>Slug</th>
                                <th>Thứ tự</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var b in Model)
                                {
                                    <tr class="single-item">
                                        <td>
                                            <div class="custom-control custom-checkbox ms-1">
                                                <input type="checkbox" class="custom-control-input checkbox" id="checkBox_@b.Id">
                                                <label class="custom-control-label" for="checkBox_@b.Id"></label>
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(b.LogoUrl))
                                            {
                                                <div class="avatar-image" style="width: 40px; height: 40px; overflow: hidden; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <img src="@b.LogoUrl" alt="@b.Name" class="img-fluid w-100 h-100" style="object-fit: cover;">
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="avatar-text bg-gray-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <i class="feather-image" style="font-size: 14px;"></i>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <span class="fw-semibold d-block" style="max-width: 150px;">@b.Name</span>
                                        </td>
                                        <td>
                                            <span class="text-muted fs-12 text-truncate d-block" style="max-width: 150px;">@b.Slug</span>
                                        </td>
                                        <td>@b.DisplayOrder</td>
                                        <td>
                                            @if (b.IsActive)
                                            {
                                                <span class="badge bg-soft-success text-success">Hiển thị</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-soft-secondary text-secondary">Ẩn</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="hstack gap-2 justify-content-end">
                                                <a asp-action="Edit" asp-route-id="@b.Id" class="avatar-text avatar-md" data-bs-toggle="tooltip" title="Sửa">
                                                    <i class="feather-edit-3"></i>
                                                </a>
                                                <div class="dropdown">
                                                    <a href="javascript:void(0)" class="avatar-text avatar-md" data-bs-toggle="dropdown" data-bs-offset="0,21">
                                                        <i class="feather-more-horizontal"></i>
                                                    </a>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@b.Id">
                                                                <i class="feather-edit-3 me-3"></i>
                                                                <span>Sửa</span>
                                                            </a>
                                                        </li>
                                                        <li class="dropdown-divider"></li>
                                                        <li>
                                                            <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="m-0">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Xóa thương hiệu này?');">
                                                                    <i class="feather-trash-2 me-3"></i>
                                                                    <span>Xóa</span>
                                                                </button>
                                                            </form>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <p class="text-muted mb-0">Chưa có thương hiệu nào.</p>
                                        <a asp-action="Create" class="btn btn-sm btn-primary mt-2">
                                            <i class="feather-plus me-2"></i>Thêm thương hiệu đầu tiên
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
