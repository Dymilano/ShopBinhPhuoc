@model IEnumerable<Brand>
@{
    ViewData["Title"] = "Thương hiệu";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Thương hiệu</h4>
    <a asp-action="Create" class="btn btn-primary">Thêm thương hiệu</a>
</div>
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Logo</th>
                    <th>Tên</th>
                    <th>Slug</th>
                    <th>Thứ tự</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(b.LogoUrl))
                            {
                                <img src="@b.LogoUrl" alt="" style="width:40px;height:40px;object-fit:contain;" />
                            }
                            else
                            {<span class="text-muted">—</span>}
                        </td>
                        <td>@b.Name</td>
                        <td>@b.Slug</td>
                        <td>@b.DisplayOrder</td>
                        <td>
                            @if (b.IsActive)
                            {<span class="badge bg-success">Hiển thị</span>}
                            else
                            {<span class="badge bg-secondary">Ẩn</span>}
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa thương hiệu này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
