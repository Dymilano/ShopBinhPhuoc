@model Brand
@{
    ViewData["Title"] = "Sửa thương hiệu";
}

@section PageHeaderRight {
    <a asp-action="Index" class="btn btn-light-brand">
        <i class="feather-arrow-left me-2"></i>
        <span>Quay lại</span>
    </a>
    <button type="submit" form="brandForm" class="btn btn-primary">
        <i class="feather-save me-2"></i>
        <span>Cập nhật thương hiệu</span>
    </button>
}

<form id="brandForm" asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-body admin-form-card">
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                    <div class="form-row">
                        <label>Logo hiện tại</label>
                        <div>
                            @if (!string.IsNullOrEmpty(Model.LogoUrl))
                            {
                                <div class="mb-2">
                                    <div class="w-100" style="max-width: 200px; height: 100px; overflow: hidden; border: 1px solid #e5e5e5; border-radius: 4px;">
                                        <img src="@Model.LogoUrl" alt="@Model.Name" class="img-fluid w-100 h-100" style="object-fit: contain; background: #f8f9fa;">
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="mb-2">
                                    <div class="w-100 d-flex align-items-center justify-content-center bg-gray-2" style="max-width: 200px; height: 100px; border: 1px solid #e5e5e5; border-radius: 4px;">
                                        <i class="feather-image" style="font-size: 24px; color: #999;"></i>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="form-row">
                        <label>Logo mới</label>
                        <div>
                            <input type="file" name="logoFile" accept="image/*">
                            <div class="fs-11 text-muted mt-1">Để trống giữ nguyên logo hiện tại. Kích thước khuyến nghị: 200x100px</div>
                        </div>
                    </div>
                    <div class="form-row">
                        <label asp-for="Name">Tên thương hiệu <span class="text-danger">*</span></label>
                        <input asp-for="Name" placeholder="Tên thương hiệu" required>
                    </div>
                    <div class="form-row">
                        <label asp-for="Slug">Slug</label>
                        <input asp-for="Slug" placeholder="Tự động nếu để trống">
                    </div>
                    <div class="form-row">
                        <label asp-for="Description">Mô tả</label>
                        <textarea asp-for="Description" rows="2" placeholder="Mô tả thương hiệu"></textarea>
                    </div>
                    <div class="form-row">
                        <label asp-for="DisplayOrder">Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" value="0" style="max-width: 150px;">
                    </div>
                    <div class="form-row">
                        <label>Trạng thái</label>
                        <div class="form-check form-switch form-switch-sm">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox">
                            <label class="form-check-label" for="IsActive">Hiển thị</label>
                        </div>
                    </div>
                    <div class="form-actions">
                        <a asp-action="Index" class="btn btn-light-brand me-2">
                            <i class="feather-x me-2"></i>
                            <span>Hủy</span>
                        </a>
                        <button type="submit">
                            <i class="feather-save me-2"></i>
                            <span>Cập nhật thương hiệu</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
