@model Brand
@{
    ViewData["Title"] = "Sửa thương hiệu";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Sửa thương hiệu</h4>
        <div>
            <a asp-action="Index" class="btn btn-light me-2">
                <i class="feather-arrow-left me-2"></i>Quay lại
            </a>
            <button type="submit" form="brandForm" class="btn btn-primary">
                <i class="feather-save me-2"></i>Cập nhật thương hiệu
            </button>
        </div>
    </div>

    <form id="brandForm" asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="alert alert-danger"></div>
        
        <div class="row">
            <!-- CỘT TRÁI -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        Thông tin thương hiệu
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Tên thương hiệu <span class="text-danger">*</span></label>
                            <input asp-for="Name" type="text" class="form-control" placeholder="Tên thương hiệu" required value="@Model.Name">
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label">Slug</label>
                            <input asp-for="Slug" type="text" class="form-control" placeholder="Để trống sẽ tự động tạo" value="@Model.Slug">
                            <small class="text-muted">Để trống sẽ tự động tạo</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả thương hiệu">@Model.Description</textarea>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Logo thương hiệu
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.LogoUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label">Logo hiện tại</label>
                                <div class="w-100" style="max-width: 200px; height: 100px; overflow: hidden; border: 1px solid #e5e5e5; border-radius: 4px;">
                                    <img src="@Model.LogoUrl" alt="@Model.Name" class="img-fluid w-100 h-100" style="object-fit: contain; background: #f8f9fa;">
                                </div>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Logo mới</label>
                            <input type="file" name="logoFile" accept="image/*" class="form-control">
                            <small class="text-muted">Để trống giữ nguyên logo hiện tại. Kích thước khuyến nghị: 200x100px</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CỘT PHẢI -->
            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        Trạng thái
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="DisplayOrder" class="form-label">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" value="@Model.DisplayOrder">
                        </div>

                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked="@Model.IsActive">
                            <label class="form-check-label" asp-for="IsActive">Hiển thị</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
