@model Brand
@{
    ViewData["Title"] = "Sửa thương hiệu";
}
<h4 class="mb-4">Sửa thương hiệu</h4>
<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="card">
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.LogoUrl))
            {
                <div class="mb-2"><img src="@Model.LogoUrl" alt="" style="max-width:80px;" /></div>
            }
            <div class="mb-3">
                <label class="form-label">Logo mới (để trống giữ nguyên)</label>
                <input type="file" name="logoFile" accept="image/*" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Slug" class="form-label"></label>
                <input asp-for="Slug" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="form-label"></label>
                <input asp-for="DisplayOrder" type="number" class="form-control" />
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </div>
</form>
