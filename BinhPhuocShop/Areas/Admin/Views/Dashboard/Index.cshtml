@{
    ViewData["Title"] = "Tổng quan";
    var productCount = ViewBag.ProductCount as int? ?? 0;
    var categoryCount = ViewBag.CategoryCount as int? ?? 0;
    var postCount = ViewBag.PostCount as int? ?? 0;
    var orderCount = ViewBag.OrderCount as int? ?? 0;
    var pendingOrders = ViewBag.PendingOrders as int? ?? 0;
    var completedOrders = ViewBag.CompletedOrders as int? ?? 0;
    var contactCount = ViewBag.ContactCount as int? ?? 0;
    var userCount = ViewBag.UserCount as int? ?? 0;
    var adminCount = ViewBag.AdminCount as int? ?? 0;
    var managerCount = ViewBag.ManagerCount as int? ?? 0;
    var customerCount = ViewBag.CustomerCount as int? ?? 0;
    var activeUserCount = ViewBag.ActiveUserCount as int? ?? 0;
    var recentOrders = ViewBag.RecentOrders as IEnumerable<BinhPhuocShop.Models.Order> ?? new List<BinhPhuocShop.Models.Order>();
    var recentProducts = ViewBag.RecentProducts as IEnumerable<BinhPhuocShop.Models.Product> ?? new List<BinhPhuocShop.Models.Product>();
    var recentPosts = ViewBag.RecentPosts as IEnumerable<BinhPhuocShop.Models.Post> ?? new List<BinhPhuocShop.Models.Post>();
    
    var totalRevenue = ViewBag.TotalRevenue as decimal? ?? 0;
    var avgOrderValue = orderCount > 0 ? totalRevenue / orderCount : 0;
}

<div class="dashboard-container">
    <!-- Report Cards Row -->
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-primary">@totalRevenue.ToString("N0")₫</h3>
                        <div class="report-card-icon" style="color: #ff9800;">
                            <i class="feather-dollar-sign"></i>
                        </div>
                    </div>
                    <p class="report-card-secondary">Tổng doanh thu</p>
                </div>
                <div class="report-card-footer" style="background-color: #ff9800;">
                    <span>@completedOrders đơn hoàn thành</span>
                    <i class="feather-trending-up"></i>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-primary">@orderCount</h3>
                        <div class="report-card-icon" style="color: #f44336;">
                            <i class="feather-shopping-cart"></i>
                        </div>
                    </div>
                    <p class="report-card-secondary">Tổng đơn hàng</p>
                </div>
                <div class="report-card-footer" style="background-color: #f44336;">
                    <span>@pendingOrders đơn đang chờ</span>
                    <i class="feather-trending-down"></i>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-primary">@productCount</h3>
                        <div class="report-card-icon" style="color: #4caf50;">
                            <i class="feather-package"></i>
                        </div>
                    </div>
                    <p class="report-card-secondary">Sản phẩm</p>
                </div>
                <div class="report-card-footer" style="background-color: #4caf50;">
                    <span>@categoryCount danh mục</span>
                    <i class="feather-trending-up"></i>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="report-card">
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-primary">@userCount</h3>
                        <div class="report-card-icon" style="color: #2196f3;">
                            <i class="feather-users"></i>
                        </div>
                    </div>
                    <p class="report-card-secondary">Người dùng</p>
                </div>
                <div class="report-card-footer" style="background-color: #2196f3;">
                    <span>@activeUserCount đang hoạt động</span>
                    <i class="feather-trending-up"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- User Statistics Row -->
    <div class="row g-3 mb-4">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">
                    <i class="feather-users me-2"></i>Thống kê người dùng
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <div class="text-center p-3 border rounded">
                                <div class="fs-3 fw-bold text-primary">@userCount</div>
                                <div class="text-muted small">Tổng người dùng</div>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <div class="text-center p-3 border rounded">
                                <div class="fs-3 fw-bold text-danger">@adminCount</div>
                                <div class="text-muted small">Quản trị viên</div>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <div class="text-center p-3 border rounded">
                                <div class="fs-3 fw-bold text-warning">@managerCount</div>
                                <div class="text-muted small">Quản lý</div>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <div class="text-center p-3 border rounded">
                                <div class="fs-3 fw-bold text-info">@customerCount</div>
                                <div class="text-muted small">Khách hàng</div>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <div class="text-center p-3 border rounded">
                                <div class="fs-3 fw-bold text-success">@activeUserCount</div>
                                <div class="text-muted small">Đang hoạt động</div>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <div class="text-center p-3 border rounded">
                                <div class="fs-3 fw-bold text-secondary">@(userCount - activeUserCount)</div>
                                <div class="text-muted small">Đã khóa</div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Users", new { area = "Admin" })" class="btn btn-sm btn-primary">
                            <i class="feather-arrow-right me-2"></i>Quản lý người dùng
                        </a>
                        <a href="@Url.Action("Create", "Users", new { area = "Admin", role = "Admin" })" class="btn btn-sm btn-danger ms-2">
                            <i class="feather-user-plus me-2"></i>Cấp tài khoản Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
        <!-- Sales Chart -->
        <div class="col-lg-8">
            <div class="card chart-card">
                <div class="card-header">
                    <h5 class="card-title">Thống kê đơn hàng theo ngày</h5>
                </div>
                <div class="card-body">
                    <div id="sales-chart" style="min-height: 300px;"></div>
                </div>
                <div class="card-footer">
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <div class="chart-stat-item">
                                <div class="chart-stat-label">Đang chờ</div>
                                <div class="chart-stat-value">@pendingOrders</div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="chart-stat-item">
                                <div class="chart-stat-label">Hoàn thành</div>
                                <div class="chart-stat-value text-success">@completedOrders</div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="chart-stat-item">
                                <div class="chart-stat-label">Tổng đơn</div>
                                <div class="chart-stat-value text-primary">@orderCount</div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <div class="chart-stat-item">
                                <div class="chart-stat-label">Giá trị TB</div>
                                <div class="chart-stat-value text-info">@avgOrderValue.ToString("N0")₫</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue Chart -->
        <div class="col-lg-4">
            <div class="card chart-card">
                <div class="card-header">
                    <h5 class="card-title">Phân loại đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div id="revenue-chart" style="min-height: 300px;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tables Row -->
    <div class="row g-3">
        <!-- Recent Orders -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Đơn hàng gần đây</h5>
                    <a href="@Url.Action("Index", "Orders", new { area = "Admin" })" class="btn btn-sm btn-light-primary">
                        Xem tất cả <i class="feather-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Khách hàng</th>
                                    <th>Mã đơn</th>
                                    <th>Ngày</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentOrders.Any())
                                {
                                    @foreach (var order in recentOrders.Take(8))
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="avatar-text avatar-sm bg-primary bg-opacity-10">
                                                        <i class="feather-user text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold">@order.CustomerName</div>
                                                        <small class="text-muted">@order.Email</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td><span class="badge bg-light text-dark">@order.OrderCode</span></td>
                                            <td>@order.CreatedAt.ToString("dd/MM/yyyy")</td>
                                            <td class="fw-bold">@order.TotalAmount.ToString("N0")₫</td>
                                            <td>
                                                @{
                                                    var statusClass = order.Status switch
                                                    {
                                                        "completed" => "bg-success",
                                                        "cancelled" => "bg-danger",
                                                        _ => "bg-warning"
                                                    };
                                                    var statusText = order.Status switch
                                                    {
                                                        "completed" => "Hoàn thành",
                                                        "cancelled" => "Đã hủy",
                                                        "confirmed" => "Đã xác nhận",
                                                        "shipping" => "Đang giao",
                                                        _ => "Đang chờ"
                                                    };
                                                }
                                                <span class="badge @statusClass">@statusText</span>
                                            </td>
                                            <td class="text-end">
                                                <a href="@Url.Action("Detail", "Orders", new { area = "Admin", id = order.Id })" class="btn btn-sm btn-light">
                                                    <i class="feather-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <i class="feather-inbox fs-1 text-muted mb-3 d-block"></i>
                                            <p class="text-muted mb-0">Chưa có đơn hàng nào</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Products & Posts -->
        <div class="col-lg-4">
            <!-- Recent Products -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Sản phẩm gần đây</h5>
                    <a href="@Url.Action("Index", "Products", new { area = "Admin" })" class="btn btn-sm btn-light-primary">
                        <i class="feather-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body">
                    @if (recentProducts.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var product in recentProducts.Take(5))
                            {
                                <div class="list-group-item px-0 py-2 border-0 border-bottom">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-image avatar-sm">
                                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                                            {
                                                <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid rounded" />
                                            }
                                            else
                                            {
                                                <div class="avatar-text avatar-sm bg-gray-200">
                                                    <i class="feather-image"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="flex-fill">
                                            <a href="@Url.Action("Edit", "Products", new { area = "Admin", id = product.Id })" class="d-block fw-semibold text-dark text-truncate">@product.Name</a>
                                            <small class="text-muted">@((product.SalePrice ?? product.Price).ToString("N0"))₫</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <i class="feather-package text-muted mb-2 d-block"></i>
                            <p class="text-muted mb-0 small">Chưa có sản phẩm</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Posts -->
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Bài viết gần đây</h5>
                    <a href="@Url.Action("Index", "Posts", new { area = "Admin" })" class="btn btn-sm btn-light-primary">
                        <i class="feather-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body">
                    @if (recentPosts.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var post in recentPosts.Take(5))
                            {
                                <div class="list-group-item px-0 py-2 border-0 border-bottom">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-text avatar-sm bg-info bg-opacity-10">
                                            <i class="feather-file-text text-info"></i>
                                        </div>
                                        <div class="flex-fill">
                                            <a href="@Url.Action("Edit", "Posts", new { area = "Admin", id = post.Id })" class="d-block fw-semibold text-dark text-truncate">@post.Title</a>
                                            <small class="text-muted">@(post.PublishedAt?.ToString("dd/MM/yyyy") ?? post.CreatedAt.ToString("dd/MM/yyyy"))</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <i class="feather-file-text text-muted mb-2 d-block"></i>
                            <p class="text-muted mb-0 small">Chưa có bài viết</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Counter animation
            const counters = document.querySelectorAll('.counter');
            counters.forEach(counter => {
                const target = parseInt(counter.textContent) || 0;
                let current = 0;
                const increment = target / 50;
                const timer = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        counter.textContent = target;
                        clearInterval(timer);
                    } else {
                        counter.textContent = Math.floor(current);
                    }
                }, 20);
            });

            // Sales Chart (Line Chart)
            const salesChartOptions = {
                series: [{
                    name: 'Đơn hàng',
                    data: [@pendingOrders, @completedOrders, @(orderCount - pendingOrders - completedOrders), @orderCount]
                }],
                chart: {
                    type: 'line',
                    height: 300,
                    toolbar: { show: false }
                },
                colors: ['#2196f3'],
                stroke: {
                    curve: 'smooth',
                    width: 3
                },
                xaxis: {
                    categories: ['Đang chờ', 'Hoàn thành', 'Đã hủy', 'Tổng']
                },
                yaxis: {
                    min: 0
                },
                tooltip: {
                    theme: 'light'
                }
            };
            const salesChart = new ApexCharts(document.querySelector("#sales-chart"), salesChartOptions);
            salesChart.render();

            // Revenue Chart (Donut Chart)
            const revenueChartOptions = {
                series: [@pendingOrders, @completedOrders, @(orderCount - pendingOrders - completedOrders)],
                chart: {
                    type: 'donut',
                    height: 300
                },
                labels: ['Đang chờ', 'Hoàn thành', 'Đã hủy'],
                colors: ['#ff9800', '#4caf50', '#f44336'],
                legend: {
                    position: 'bottom'
                },
                dataLabels: {
                    enabled: true,
                    formatter: function(val) {
                        return val.toFixed(1) + "%";
                    }
                }
            };
            const revenueChart = new ApexCharts(document.querySelector("#revenue-chart"), revenueChartOptions);
            revenueChart.render();
        });
    </script>
}
