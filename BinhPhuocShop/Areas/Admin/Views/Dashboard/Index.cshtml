@{
    ViewData["Title"] = "Tổng quan";
    var productCount = ViewBag.ProductCount as int? ?? 0;
    var categoryCount = ViewBag.CategoryCount as int? ?? 0;
    var postCount = ViewBag.PostCount as int? ?? 0;
    var orderCount = ViewBag.OrderCount as int? ?? 0;
    var contactCount = ViewBag.ContactCount as int? ?? 0;
    var userCount = ViewBag.UserCount as int? ?? 0;
    var recentOrders = ViewBag.RecentOrders as IEnumerable<BinhPhuocShop.Models.Order> ?? new List<BinhPhuocShop.Models.Order>();
}

<!-- General Report (Cleopatra) -->
<div class="grid grid-cols-4 gap-6 xl:grid-cols-1">
    <div class="report-card">
        <div class="card">
            <div class="card-body flex flex-col">
                <div class="flex flex-row justify-between items-center">
                    <div class="h6 text-indigo-700 fad fa-shopping-cart"></div>
                    <span class="rounded-full text-white badge bg-teal-400 text-xs">
                        <i class="fal fa-chevron-up ml-1"></i>
                    </span>
                </div>
                <div class="mt-8">
                    <h1 class="h5">@productCount</h1>
                    <p>Sản phẩm</p>
                </div>
            </div>
        </div>
        <div class="footer bg-white p-1 mx-4 border border-t-0 rounded rounded-t-none"></div>
    </div>
    <div class="report-card">
        <div class="card">
            <div class="card-body flex flex-col">
                <div class="flex flex-row justify-between items-center">
                    <div class="h6 text-red-700 fad fa-store"></div>
                    <span class="rounded-full text-white badge bg-teal-400 text-xs">
                        <i class="fal fa-chevron-up ml-1"></i>
                    </span>
                </div>
                <div class="mt-8">
                    <h1 class="h5">@orderCount</h1>
                    <p>Đơn hàng</p>
                </div>
            </div>
        </div>
        <div class="footer bg-white p-1 mx-4 border border-t-0 rounded rounded-t-none"></div>
    </div>
    <div class="report-card">
        <div class="card">
            <div class="card-body flex flex-col">
                <div class="flex flex-row justify-between items-center">
                    <div class="h6 text-yellow-600 fad fa-sitemap"></div>
                    <span class="rounded-full text-white badge bg-teal-400 text-xs">
                        <i class="fal fa-chevron-up ml-1"></i>
                    </span>
                </div>
                <div class="mt-8">
                    <h1 class="h5">@categoryCount</h1>
                    <p>Danh mục</p>
                </div>
            </div>
        </div>
        <div class="footer bg-white p-1 mx-4 border border-t-0 rounded rounded-t-none"></div>
    </div>
    <div class="report-card">
        <div class="card">
            <div class="card-body flex flex-col">
                <div class="flex flex-row justify-between items-center">
                    <div class="h6 text-green-700 fad fa-users"></div>
                    <span class="rounded-full text-white badge bg-teal-400 text-xs">
                        <i class="fal fa-chevron-up ml-1"></i>
                    </span>
                </div>
                <div class="mt-8">
                    <h1 class="h5">@contactCount</h1>
                    <p>Tin nhắn chưa đọc</p>
                </div>
            </div>
        </div>
        <div class="footer bg-white p-1 mx-4 border border-t-0 rounded rounded-t-none"></div>
    </div>
</div>

<!-- Analytics / Welcome (Cleopatra) -->
<div class="mt-6 grid grid-cols-2 gap-6 xl:grid-cols-1">
    <div class="card bg-teal-400 border-teal-400 shadow-md text-white">
        <div class="card-body flex flex-row">
            <div class="w-24 h-24 flex justify-center items-center rounded-full bg-white/20">
                <i class="fad fa-store fa-3x opacity-90"></i>
            </div>
            <div class="py-2 ml-10">
                <h1 class="h6">Chào mừng đến Bình Phước Shop!</h1>
                <p class="text-white text-xs">Quản lý sản phẩm, đơn hàng và nội dung tại đây.</p>
                <ul class="mt-4">
                    <li class="text-sm font-light"><i class="fad fa-check-double mr-2 mb-2"></i> @productCount sản phẩm</li>
                    <li class="text-sm font-light"><i class="fad fa-check-double mr-2 mb-2"></i> @orderCount đơn hàng</li>
                    <li class="text-sm font-light"><i class="fad fa-check-double mr-2"></i> @postCount bài viết</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="flex flex-col">
        <div class="alert alert-dark mb-6">
            <i class="fad fa-info-circle mr-2"></i>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="hover:text-teal-600">Quản lý sản phẩm</a>
            ·
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="hover:text-teal-600 ml-1">Xem đơn hàng</a>
        </div>
        <div class="grid grid-cols-2 gap-6 h-full">
            <div class="card">
                <div class="py-3 px-4 flex flex-row justify-between">
                    <h1 class="h6">
                        @productCount
                        <p>Sản phẩm</p>
                    </h1>
                    <div class="bg-teal-200 text-teal-700 border-teal-300 border w-10 h-10 rounded-full flex justify-center items-center">
                        <i class="fad fa-box"></i>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="py-3 px-4 flex flex-row justify-between">
                    <h1 class="h6">
                        @orderCount
                        <p>Đơn hàng</p>
                    </h1>
                    <div class="bg-indigo-200 text-indigo-700 border-indigo-300 border w-10 h-10 rounded-full flex justify-center items-center">
                        <i class="fad fa-shopping-cart"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sales Overview (Cleopatra) -->
<div class="card mt-6">
    <div class="card-header flex flex-row justify-between">
        <h1 class="h6">Tổng quan đơn hàng</h1>
        <div class="flex flex-row justify-center items-center">
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index"><i class="fad fa-ellipsis-v"></i></a>
        </div>
    </div>
    <div class="card-body grid grid-cols-2 gap-6 lg:grid-cols-1">
        <div class="p-8">
            <h1 class="h2">@orderCount</h1>
            <p class="text-black font-medium">Tổng đơn hàng</p>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn-shadow mt-6 inline-block">Xem đơn hàng</a>
        </div>
    </div>
</div>

<!-- Numbers (Cleopatra) -->
<div class="grid grid-cols-5 gap-6 xl:grid-cols-2 mt-6">
    <div class="card">
        <div class="card-body flex items-center">
            <div class="px-3 py-2 rounded bg-indigo-600 text-white mr-3">
                <i class="fad fa-shopping-bag"></i>
            </div>
            <div class="flex flex-col">
                <h1 class="font-semibold">@productCount</h1>
                <p class="text-xs">Sản phẩm</p>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body flex items-center">
            <div class="px-3 py-2 rounded bg-green-600 text-white mr-3">
                <i class="fad fa-shopping-cart"></i>
            </div>
            <div class="flex flex-col">
                <h1 class="font-semibold">@orderCount</h1>
                <p class="text-xs">Đơn hàng</p>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body flex items-center">
            <div class="px-3 py-2 rounded bg-yellow-600 text-white mr-3">
                <i class="fad fa-blog"></i>
            </div>
            <div class="flex flex-col">
                <h1 class="font-semibold">@postCount</h1>
                <p class="text-xs">Bài viết</p>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body flex items-center">
            <div class="px-3 py-2 rounded bg-red-600 text-white mr-3">
                <i class="fad fa-mail"></i>
            </div>
            <div class="flex flex-col">
                <h1 class="font-semibold">@contactCount</h1>
                <p class="text-xs">Liên hệ chưa đọc</p>
            </div>
        </div>
    </div>
    <div class="card xl:col-span-2">
        <div class="card-body flex items-center">
            <div class="px-3 py-2 rounded bg-pink-600 text-white mr-3">
                <i class="fad fa-user"></i>
            </div>
            <div class="flex flex-col">
                <h1 class="font-semibold">@userCount</h1>
                <p class="text-xs">Tài khoản</p>
            </div>
        </div>
    </div>
</div>

<!-- Recent Sales (Cleopatra) -->
<div class="grid grid-cols-3 gap-6 mt-6 xl:grid-cols-1">
    <div class="card col-span-2 xl:col-span-1">
        <div class="card-header">Đơn hàng gần đây</div>
        <table class="table-auto w-full text-left">
            <thead>
                <tr>
                    <th class="px-4 py-2 border-r">Mã đơn</th>
                    <th class="px-4 py-2 border-r">Khách hàng</th>
                    <th class="px-4 py-2 border-r">Tổng tiền</th>
                    <th class="px-4 py-2">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="text-gray-600">
                @if (recentOrders.Any())
                {
                    @foreach (var o in recentOrders)
                    {
                        <tr>
                            <td class="border border-l-0 px-4 py-2">
                                <a asp-area="Admin" asp-controller="Orders" asp-action="Detail" asp-route-id="@o.Id" class="text-teal-600 hover:underline">@o.OrderCode</a>
                            </td>
                            <td class="border border-l-0 px-4 py-2">@o.CustomerName</td>
                            <td class="border border-l-0 px-4 py-2">@(o.TotalAmount.ToString("N0"))₫</td>
                            <td class="border border-l-0 border-r-0 px-4 py-2">
                                <span class="text-xs px-2 py-1 rounded @(o.Status == "completed" ? "bg-green-100 text-green-800" : o.Status == "cancelled" ? "bg-red-100 text-red-800" : "bg-yellow-100 text-yellow-800")">@o.Status</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="border px-4 py-6 text-center text-gray-500">Chưa có đơn hàng nào.</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (recentOrders.Any())
        {
            <div class="p-4 border-t">
                <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="text-teal-600 hover:text-teal-700 text-sm">Xem tất cả đơn hàng →</a>
            </div>
        }
    </div>
    <div class="card">
        <div class="card-header">Thao tác nhanh</div>
        <div class="p-6 flex flex-col gap-3">
            <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="flex items-center p-3 rounded border hover:bg-gray-50 transition">
                <i class="fad fa-plus text-teal-600 mr-3"></i>
                <span>Thêm sản phẩm</span>
            </a>
            <a asp-area="Admin" asp-controller="Posts" asp-action="Create" class="flex items-center p-3 rounded border hover:bg-gray-50 transition">
                <i class="fad fa-file-plus text-teal-600 mr-3"></i>
                <span>Thêm bài viết</span>
            </a>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="flex items-center p-3 rounded border hover:bg-gray-50 transition">
                <i class="fad fa-list text-teal-600 mr-3"></i>
                <span>Xem đơn hàng</span>
            </a>
            <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index" class="flex items-center p-3 rounded border hover:bg-gray-50 transition">
                <i class="fad fa-inbox text-teal-600 mr-3"></i>
                <span>Tin nhắn liên hệ</span>
            </a>
        </div>
    </div>
</div>
