@{
    var adminBase = "/admin";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] | Bình Phước Shop - Admin</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v5.12.1/css/pro.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/feather-icons@4.28.0/dist/feather.css">
    <link rel="stylesheet" type="text/css" href="@(adminBase)/css/style.css">
    <link rel="stylesheet" type="text/css" href="~/css/site-admin.css">
</head>
<body class="bg-light">
@Html.AntiForgeryToken()

<!-- Top Navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px; font-weight: bold;">BP</div>
            <strong class="text-primary">Bình Phước Shop</strong>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item me-3">
                    <a class="nav-link" href="@Url.Action("Index", "Home", new { area = "" })" target="_blank" title="Xem trang chủ">
                        <i class="bi bi-house-door"></i>
                    </a>
                </li>
                <li class="nav-item dropdown me-3">
                    <a class="nav-link position-relative" href="#" id="notificationsDropdown" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        @{
                            var pendingOrdersCount = ViewBag.PendingOrdersCount as int? ?? 0;
                        }
                        @if (pendingOrdersCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@pendingOrdersCount</span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" style="min-width: 300px;">
                        <li><h6 class="dropdown-header">Thông báo</h6></li>
                        <li><hr class="dropdown-divider"></li>
                        @if (pendingOrdersCount > 0)
                        {
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "Orders", new { area = "Admin", status = "pending" })">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Đơn hàng đang chờ</span>
                                        <span class="badge bg-warning text-dark">@pendingOrdersCount</span>
                                    </div>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li><span class="dropdown-item-text text-muted">Chưa có thông báo mới</span></li>
                        }
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-center" href="@Url.Action("Index", "Orders", new { area = "Admin" })">Xem tất cả đơn hàng</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown me-3">
                    <a class="nav-link position-relative" href="#" id="messagesDropdown" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-envelope"></i>
                        @{
                            var unreadContactsCount = ViewBag.UnreadContactsCount as int? ?? 0;
                        }
                        @if (unreadContactsCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@unreadContactsCount</span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" style="min-width: 300px;">
                        <li><h6 class="dropdown-header">Liên hệ</h6></li>
                        <li><hr class="dropdown-divider"></li>
                        @if (unreadContactsCount > 0)
                        {
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "ContactMessages", new { area = "Admin" })">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Tin nhắn mới</span>
                                        <span class="badge bg-info">@unreadContactsCount</span>
                                    </div>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li><span class="dropdown-item-text text-muted">Chưa có tin nhắn mới</span></li>
                        }
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-center" href="@Url.Action("Index", "ContactMessages", new { area = "Admin" })">Xem tất cả</a></li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                            <i class="bi bi-person"></i>
                        </div>
                        <span>Admin</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="@Url.Action("Index", "Home", new { area = "" })" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i>Xem trang chủ</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-white border-end sidebar collapse">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                            <i class="bi bi-speedometer2 me-2"></i> Tổng quan
                        </a>
                    </li>
                    <li class="nav-item mt-2">
                        <small class="text-muted text-uppercase px-3">Sản phẩm</small>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")" href="@Url.Action("Index", "Products", new { area = "Admin" })">
                            <i class="bi bi-box-seam me-2"></i> Danh sách
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Create", "Products", new { area = "Admin" })">
                            <i class="bi bi-plus-circle me-2"></i> Thêm sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")" href="@Url.Action("Index", "Categories", new { area = "Admin" })">
                            <i class="bi bi-folder me-2"></i> Danh mục
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Create", "Categories", new { area = "Admin" })">
                            <i class="bi bi-plus-circle me-2"></i> Thêm danh mục
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Brands" ? "active" : "")" href="@Url.Action("Index", "Brands", new { area = "Admin" })">
                            <i class="bi bi-award me-2"></i> Thương hiệu
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Create", "Brands", new { area = "Admin" })">
                            <i class="bi bi-plus-circle me-2"></i> Thêm thương hiệu
                        </a>
                    </li>
                    <li class="nav-item mt-2">
                        <small class="text-muted text-uppercase px-3">Nội dung</small>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Posts" ? "active" : "")" href="@Url.Action("Index", "Posts", new { area = "Admin" })">
                            <i class="bi bi-file-text me-2"></i> Bài viết
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Create", "Posts", new { area = "Admin" })">
                            <i class="bi bi-plus-circle me-2"></i> Thêm bài viết
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pages" ? "active" : "")" href="@Url.Action("EditGioiThieu", "Pages", new { area = "Admin" })">
                            <i class="bi bi-pencil me-2"></i> Sửa Giới thiệu
                        </a>
                    </li>
                    <li class="nav-item mt-2">
                        <small class="text-muted text-uppercase px-3">Bán hàng</small>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")" href="@Url.Action("Index", "Orders", new { area = "Admin" })">
                            <i class="bi bi-cart me-2"></i> Đơn hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ContactMessages" ? "active" : "")" href="@Url.Action("Index", "ContactMessages", new { area = "Admin" })">
                            <i class="bi bi-envelope me-2"></i> Liên hệ
                        </a>
                    </li>
                    <li class="nav-item mt-2">
                        <small class="text-muted text-uppercase px-3">Hệ thống</small>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")" href="@Url.Action("Index", "Users", new { area = "Admin" })">
                            <i class="bi bi-people me-2"></i> Người dùng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Create", "Users", new { area = "Admin", role = "Admin" })">
                            <i class="bi bi-person-plus me-2"></i> Cấp tài khoản Admin
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ActivityLogs" ? "active" : "")" href="@Url.Action("Index", "ActivityLogs", new { area = "Admin" })">
                            <i class="bi bi-clock-history me-2"></i> Lịch sử hoạt động
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")" href="@Url.Action("Index", "Settings", new { area = "Admin" })">
                            <i class="bi bi-gear me-2"></i> Cài đặt
                        </a>
                    </li>
                    <li class="nav-item mt-3">
                        <hr>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home", new { area = "" })" target="_blank">
                            <i class="bi bi-box-arrow-up-right me-2"></i> Xem trang web
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <div>
                    <h1 class="h2 mb-1">@ViewData["Title"]</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">Bình Phước Shop</a></li>
                            <li class="breadcrumb-item active">@ViewData["Title"]</li>
                        </ol>
                    </nav>
                </div>
                <div class="d-flex gap-2">
                    @await RenderSectionAsync("PageHeaderRight", required: false)
                </div>
            </div>
            @RenderBody()
            <footer class="my-5 pt-4 border-top text-center text-muted">
                <small>© <span id="current-year"></span> <strong>Bình Phước Shop</strong>. All rights reserved.</small>
            </footer>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/feather-icons@4.28.0/dist/feather.min.js"></script>
<script src="@(adminBase)/js/scripts.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize Feather Icons
        if (typeof feather !== 'undefined') {
            feather.replace();
        }
        
        // Set current year
        var yearEl = document.getElementById('current-year');
        if (yearEl) yearEl.textContent = new Date().getFullYear();
        
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
