@{
    var userName = Context.Session.GetString("UserName") ?? "Admin";
    var userEmail = Context.Session.GetString("UserEmail") ?? "admin@binhphuocshop.vn";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="" />
    <meta name="keyword" content="" />
    <meta name="author" content="BinhPhuocShop" />
    <title>@ViewData["Title"] || Bình Phước Shop Admin</title>
    <link rel="shortcut icon" type="image/x-icon" href="/duralux/images/favicon.ico" />
    <link rel="stylesheet" type="text/css" href="/duralux/css/bootstrap.min.css" />
    <link rel="stylesheet" type="text/css" href="/duralux/vendors/css/vendors.min.css" />
    <link rel="stylesheet" type="text/css" href="/duralux/vendors/css/daterangepicker.min.css" />
    <link rel="stylesheet" type="text/css" href="/duralux/css/theme.min.css" />
    <style>
        /* Custom Form Styles - Balanced Layout */
        body {
            background: #f4f6fa;
            font-family: 'Segoe UI', sans-serif;
        }

        .admin-form {
            background: #fff;
            max-width: 900px;
            margin: 30px auto;
            padding: 35px 40px;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .admin-form-card {
            background: #fff;
            padding: 35px 40px;
            border-radius: 14px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            border: none;
        }

        .form-title {
            margin-bottom: 30px;
            font-weight: 600;
            font-size: 20px;
            color: #333;
        }

        .form-row {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .form-row label,
        .admin-form-label {
            width: 180px;
            font-weight: 600;
            color: #444;
            font-size: 14px;
            flex-shrink: 0;
        }

        .form-row input,
        .form-row textarea,
        .form-row select,
        .admin-form-input,
        .admin-form-textarea,
        .admin-form-select {
            flex: 1;
            padding: 11px 14px;
            border-radius: 10px;
            border: 1px solid #e2e2e2;
            background: #fafafa;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .form-row textarea,
        .admin-form-textarea {
            min-height: 100px;
            resize: vertical;
        }

        .form-row input:focus,
        .form-row textarea:focus,
        .form-row select:focus,
        .admin-form-input:focus,
        .admin-form-textarea:focus,
        .admin-form-select:focus {
            background: #fff;
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
            outline: none;
        }

        .form-actions {
            text-align: right;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }

        .form-actions button,
        .admin-btn-primary {
            padding: 10px 26px;
            border-radius: 10px;
            border: none;
            background: linear-gradient(135deg, #4f46e5, #6366f1);
            color: #fff;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .form-actions button:hover,
        .admin-btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(79,70,229,0.3);
        }

        .form-actions button:active,
        .admin-btn-primary:active {
            transform: translateY(0);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .form-row {
                flex-direction: column;
                align-items: flex-start;
            }

            .form-row label,
            .admin-form-label {
                width: 100%;
                margin-bottom: 8px;
            }

            .form-row input,
            .form-row textarea,
            .form-row select,
            .admin-form-input,
            .admin-form-textarea,
            .admin-form-select {
                width: 100%;
            }

            .admin-form,
            .admin-form-card {
                padding: 25px 20px;
                margin: 20px 10px;
            }
        }

        /* Input Group Styling */
        .input-group .input-group-text {
            background: #f5f7fb;
            border: 1px solid #e2e2e2;
            border-right: none;
            border-radius: 10px 0 0 10px;
        }

        .input-group .form-control {
            border-left: none;
            border-radius: 0 10px 10px 0;
        }

        .input-group .form-control:focus {
            border-left: 1px solid #4f46e5;
        }

        /* Checkbox and Switch */
        .form-row .form-check {
            margin-top: 0;
        }

        .form-row .form-check-label {
            width: auto;
            margin-left: 8px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @Html.AntiForgeryToken()
