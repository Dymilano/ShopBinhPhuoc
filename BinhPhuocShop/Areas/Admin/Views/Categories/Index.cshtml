@model IEnumerable<Category>
@{
    ViewData["Title"] = "Danh mục";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Danh mục</h4>
    <a asp-action="Create" class="btn btn-primary">Thêm danh mục</a>
</div>
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Tên</th>
                    <th>Slug</th>
                    <th>Danh mục cha</th>
                    <th>Thứ tự</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td>@c.Name</td>
                        <td>@c.Slug</td>
                        <td>@(c.Parent?.Name ?? "—")</td>
                        <td>@c.DisplayOrder</td>
                        <td>
                            @if (c.IsActive)
                            {<span class="badge bg-success">Hiển thị</span>}
                            else
                            {<span class="badge bg-secondary">Ẩn</span>}
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa danh mục này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
