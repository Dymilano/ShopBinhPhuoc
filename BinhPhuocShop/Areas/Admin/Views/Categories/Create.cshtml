@model Category
@{
    ViewData["Title"] = "Thêm danh mục";
}

@section PageHeaderRight {
    <a asp-action="Index" class="btn btn-light-brand">
        <i class="feather-arrow-left me-2"></i>
        <span>Quay lại</span>
    </a>
    <button type="submit" form="categoryForm" class="btn btn-primary">
        <i class="feather-save me-2"></i>
        <span>Lưu danh mục</span>
    </button>
}

<form id="categoryForm" asp-action="Create" method="post">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-body admin-form-card">
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                    <div class="form-row">
                        <label asp-for="Name">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="Name" placeholder="Tên danh mục" required>
                    </div>
                    <div class="form-row">
                        <label asp-for="Slug">Slug</label>
                        <input asp-for="Slug" placeholder="Tự động nếu để trống">
                    </div>
                    <div class="form-row">
                        <label asp-for="Description">Mô tả</label>
                        <textarea asp-for="Description" rows="2" placeholder="Mô tả danh mục"></textarea>
                    </div>
                    <div class="form-row">
                        <label asp-for="ParentId">Danh mục cha</label>
                        <select asp-for="ParentId" asp-items="ViewBag.Parents">
                            <option value="">— Không có —</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <label asp-for="DisplayOrder">Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" value="0" style="max-width: 150px;">
                    </div>
                    <div class="form-row">
                        <label>Trạng thái</label>
                        <div class="form-check form-switch form-switch-sm">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                            <label class="form-check-label" for="IsActive">Hiển thị</label>
                        </div>
                    </div>
                    <div class="form-actions">
                        <a asp-action="Index" class="btn btn-light-brand me-2">
                            <i class="feather-x me-2"></i>
                            <span>Hủy</span>
                        </a>
                        <button type="submit">
                            <i class="feather-save me-2"></i>
                            <span>Lưu danh mục</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
