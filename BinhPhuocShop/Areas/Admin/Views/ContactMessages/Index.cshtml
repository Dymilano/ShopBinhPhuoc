@model IEnumerable<ContactMessage>
@{
    ViewData["Title"] = "Tin nhắn liên hệ";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card stretch stretch-full">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="wd-30">
                                    <div class="custom-control custom-checkbox ms-1">
                                        <input type="checkbox" class="custom-control-input" id="checkAll">
                                        <label class="custom-control-label" for="checkAll"></label>
                                    </div>
                                </th>
                                <th>Ngày</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Tiêu đề</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var m in Model)
                                {
                                    <tr class="single-item @(!m.IsRead ? "table-warning" : "")">
                                        <td>
                                            <div class="custom-control custom-checkbox ms-1">
                                                <input type="checkbox" class="custom-control-input checkbox" id="checkBox_@m.Id">
                                                <label class="custom-control-label" for="checkBox_@m.Id"></label>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-muted">@m.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold">@m.Name</span>
                                        </td>
                                        <td>
                                            <a href="mailto:@m.Email">@m.Email</a>
                                        </td>
                                        <td>
                                            <span class="text-truncate-1-line d-block" style="max-width: 250px;">@m.Subject</span>
                                        </td>
                                        <td>
                                            @if (m.IsRead)
                                            {
                                                <span class="badge bg-success">Đã đọc</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">Chưa đọc</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="hstack gap-2 justify-content-end">
                                                <a asp-action="Detail" asp-route-id="@m.Id" class="avatar-text avatar-md" data-bs-toggle="tooltip" title="Xem chi tiết">
                                                    <i class="feather-eye"></i>
                                                </a>
                                                <div class="dropdown">
                                                    <a href="javascript:void(0)" class="avatar-text avatar-md" data-bs-toggle="dropdown" data-bs-offset="0,21">
                                                        <i class="feather-more-horizontal"></i>
                                                    </a>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item" asp-action="Detail" asp-route-id="@m.Id">
                                                                <i class="feather-eye me-3"></i>
                                                                <span>Xem chi tiết</span>
                                                            </a>
                                                        </li>
                                                        <li class="dropdown-divider"></li>
                                                        <li>
                                                            <form asp-action="Delete" asp-route-id="@m.Id" method="post" class="m-0">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Xóa tin nhắn này?');">
                                                                    <i class="feather-trash-2 me-3"></i>
                                                                    <span>Xóa</span>
                                                                </button>
                                                            </form>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <p class="text-muted mb-0">Chưa có tin nhắn nào.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
