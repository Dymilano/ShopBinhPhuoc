@model IEnumerable<Post>
@{
    ViewData["Title"] = "Bài viết";
}

@section PageHeaderRight {
    <a asp-action="Create" class="btn btn-primary">
        <i class="feather-plus me-2"></i>
        <span>Thêm bài viết</span>
    </a>
}

<div class="row">
    <div class="col-lg-12">
        <div class="card stretch stretch-full">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="wd-30">
                                    <div class="custom-control custom-checkbox ms-1">
                                        <input type="checkbox" class="custom-control-input" id="checkAll">
                                        <label class="custom-control-label" for="checkAll"></label>
                                    </div>
                                </th>
                                <th>Ảnh</th>
                                <th>Tiêu đề</th>
                                <th>Danh mục</th>
                                <th>Ngày đăng</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var p in Model)
                                {
                                    <tr class="single-item">
                                        <td>
                                            <div class="custom-control custom-checkbox ms-1">
                                                <input type="checkbox" class="custom-control-input checkbox" id="checkBox_@p.Id">
                                                <label class="custom-control-label" for="checkBox_@p.Id"></label>
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                                            {
                                                <div class="avatar-image" style="width: 40px; height: 40px; overflow: hidden; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <img src="@p.ImageUrl" alt="@p.Title" class="img-fluid w-100 h-100" style="object-fit: cover;">
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="avatar-text bg-gray-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-radius: 4px; border: 1px solid #e5e5e5;">
                                                    <i class="feather-image" style="font-size: 14px;"></i>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <div>
                                                <span class="fw-semibold d-block mb-1" style="max-width: 250px;">@p.Title</span>
                                                @if (!string.IsNullOrEmpty(p.Summary))
                                                {
                                                    <span class="fs-11 text-muted text-truncate-2-line d-block" style="max-width: 250px; line-height: 1.4;">@p.Summary</span>
                                                }
                                                else if (!string.IsNullOrEmpty(p.Content))
                                                {
                                                    var plainText = System.Text.RegularExpressions.Regex.Replace(p.Content, "<.*?>", string.Empty);
                                                    var truncated = plainText.Length > 80 ? plainText.Substring(0, 80) + "..." : plainText;
                                                    <span class="fs-11 text-muted text-truncate-2-line d-block" style="max-width: 250px; line-height: 1.4;">@truncated</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-soft-primary text-primary">@(p.BlogCategory ?? "—")</span>
                                        </td>
                                        <td>
                                            <span class="text-muted">@(p.PublishedAt?.ToString("dd/MM/yyyy") ?? p.CreatedAt.ToString("dd/MM/yyyy"))</span>
                                        </td>
                                        <td>
                                            @if (p.IsActive)
                                            {
                                                <span class="badge bg-soft-success text-success">Hiển thị</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-soft-secondary text-secondary">Ẩn</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group" role="group">
                                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a href="@Url.Action("Detail", "Blog", new { area = "", slug = p.Slug })" target="_blank" class="btn btn-sm btn-outline-info" title="Xem trên trang web">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa bài viết này?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Xóa">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <p class="text-muted mb-0">Chưa có bài viết nào.</p>
                                        <a asp-action="Create" class="btn btn-sm btn-primary mt-2">
                                            <i class="feather-plus me-2"></i>Thêm bài viết đầu tiên
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
