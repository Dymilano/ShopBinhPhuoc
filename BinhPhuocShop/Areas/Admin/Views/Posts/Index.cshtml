@model IEnumerable<Post>
@{
    ViewData["Title"] = "Bài viết";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Bài viết</h4>
    <a asp-action="Create" class="btn btn-primary">Thêm bài viết</a>
</div>
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Slug</th>
                    <th>Ngày đăng</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Title</td>
                        <td>@p.Slug</td>
                        <td>@p.PublishedAt?.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (p.IsActive)
                            {<span class="badge bg-success">Hiển thị</span>}
                            else
                            {<span class="badge bg-secondary">Ẩn</span>}
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa bài viết này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
