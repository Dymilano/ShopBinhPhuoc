@model Post
@{
    ViewData["Title"] = "Thêm bài viết";
}

@section PageHeaderRight {
    <a asp-action="Index" class="btn btn-light-brand">
        <i class="feather-arrow-left me-2"></i>
        <span>Quay lại</span>
    </a>
    <button type="submit" form="postForm" class="btn btn-primary">
        <i class="feather-save me-2"></i>
        <span>Lưu bài viết</span>
    </button>
}

<form id="postForm" asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-body">
                    <div asp-validation-summary="All" class="alert alert-danger"></div>
                    <div class="row mb-3 align-items-center">
                        <div class="col-lg-3">
                            <label asp-for="Title" class="fw-semibold mb-0">Tiêu đề: <span class="text-danger">*</span></label>
                        </div>
                        <div class="col-lg-9">
                            <div class="input-group input-group-sm">
                                <div class="input-group-text"><i class="feather-file-text"></i></div>
                                <input asp-for="Title" class="form-control" placeholder="Tiêu đề bài viết" required>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <div class="col-lg-3">
                            <label asp-for="Slug" class="fw-semibold mb-0">Slug: </label>
                        </div>
                        <div class="col-lg-9">
                            <div class="input-group input-group-sm">
                                <div class="input-group-text"><i class="feather-link-2"></i></div>
                                <input asp-for="Slug" class="form-control" placeholder="Tự động nếu để trống">
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <div class="col-lg-3">
                            <label asp-for="Summary" class="fw-semibold mb-0">Tóm tắt: </label>
                        </div>
                        <div class="col-lg-9">
                            <textarea asp-for="Summary" class="form-control form-control-sm" rows="2" placeholder="Tóm tắt bài viết"></textarea>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <div class="col-lg-3">
                            <label class="fw-semibold mb-0">Ảnh đại diện: </label>
                        </div>
                        <div class="col-lg-9">
                            <div class="input-group input-group-sm">
                                <div class="input-group-text"><i class="feather-image"></i></div>
                                <input type="file" name="imageFile" accept="image/*" class="form-control">
                            </div>
                            <div class="fs-11 text-muted mt-1">Kích thước khuyến nghị: 600x400px. Định dạng: JPG, PNG</div>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-start">
                        <div class="col-lg-3">
                            <label asp-for="Content" class="fw-semibold mb-0">Nội dung (HTML): </label>
                        </div>
                        <div class="col-lg-9">
                            <textarea id="Content" name="Content" class="form-control form-control-sm" rows="8" placeholder="Nội dung bài viết">@Model.Content</textarea>
                            <div class="mt-2 p-2 border border-gray-2 rounded bg-gray-1">
                                <label class="fs-11 fw-semibold mb-1 d-block">Chèn ảnh vào nội dung:</label>
                                <div class="input-group input-group-sm">
                                    <input type="file" id="contentImageFile" accept="image/*" class="form-control form-control-sm">
                                    <button type="button" class="btn btn-sm btn-light-brand" id="btnUploadContentImage">Tải lên và chèn</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <div class="col-lg-3">
                            <label asp-for="PublishedAt" class="fw-semibold mb-0">Ngày đăng: </label>
                        </div>
                        <div class="col-lg-9">
                            <div class="input-group input-group-sm" style="max-width: 300px;">
                                <div class="input-group-text"><i class="feather-calendar"></i></div>
                                <input asp-for="PublishedAt" type="datetime-local" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <div class="col-lg-3">
                            <label class="fw-semibold mb-0">Trạng thái: </label>
                        </div>
                        <div class="col-lg-9">
                            <div class="form-check form-switch form-switch-sm">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                                <label class="form-check-label" for="IsActive">Hiển thị</label>
                            </div>
                            <div class="form-check form-switch form-switch-sm mt-2">
                                <input asp-for="IsPinned" class="form-check-input" type="checkbox">
                                <label class="form-check-label" for="IsPinned">Ghim</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light-brand">
                        <i class="feather-x me-2"></i>
                        <span>Hủy</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="feather-save me-2"></i>
                        <span>Lưu bài viết</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
(function() {
  var ta = document.getElementById('Content');
  var input = document.getElementById('contentImageFile');
  var btn = document.getElementById('btnUploadContentImage');
  if (btn && input && ta) {
    btn.addEventListener('click', function() {
      if (!input.files || !input.files[0]) { alert('Chọn ảnh trước.'); return; }
      var fd = new FormData();
      fd.append('file', input.files[0]);
      fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
      btn.disabled = true;
      fetch('/Admin/Upload/ContentImage', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          btn.disabled = false;
          if (data.ok && data.url) {
            var img = '<img src="' + data.url + '" alt="" style="max-width:100%; height:auto;" />';
            var start = ta.selectionStart, end = ta.selectionEnd;
            ta.value = ta.value.slice(0, start) + img + ta.value.slice(end);
            ta.focus();
            input.value = '';
          } else { alert(data.msg || 'Lỗi tải ảnh'); }
        })
        .catch(function() { btn.disabled = false; alert('Lỗi tải ảnh'); });
    });
  }
})();
</script>
}
